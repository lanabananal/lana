---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  postSlug: string;
  locale: string;
  author: string;
  tags?: string[];
  readMore: string;
}

const { title, description, pubDate, postSlug, locale, author, tags, readMore } = Astro.props;

const formattedDate = pubDate.toLocaleDateString(
  locale === 'pt-br' ? 'pt-BR' : locale === 'pl' ? 'pl-PL' : locale === 'es' ? 'es-ES' : 'en-US',
  { year: 'numeric', month: 'short', day: 'numeric' }
);
---

<article class="card flex flex-col h-full hover:-translate-y-0.5 transition-all duration-200 group">
  <!-- Tags -->
  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.slice(0, 2).map(tag => (
        <span class="px-2.5 py-0.5 bg-brand-50 text-brand-700 text-xs font-semibold rounded-full">{tag}</span>
      ))}
    </div>
  )}

  <h2 class="text-lg font-bold text-slate-900 mb-2 group-hover:text-brand-700 transition-colors leading-snug">
    <a href={`/${locale}/blog/${postSlug}`} class="stretched-link">{title}</a>
  </h2>

  <p class="text-slate-500 text-sm leading-relaxed flex-1 mb-5">{description}</p>

  <div class="flex items-center justify-between pt-4 border-t border-slate-100">
    <div class="flex items-center gap-2">
      <div class="w-7 h-7 rounded-full bg-brand-600 flex items-center justify-center text-white text-xs font-bold">C</div>
      <span class="text-xs text-slate-500">{author}</span>
    </div>
    <time class="text-xs text-slate-400">{formattedDate}</time>
  </div>
</article>

<style>
  article {
    position: relative;
  }
  .stretched-link::after {
    position: absolute;
    inset: 0;
    content: '';
    z-index: 1;
  }
</style>
