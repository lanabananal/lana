---
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="services" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="section-label mb-4">{t.services.title}</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mt-4 mb-4">{t.services.title}</h2>
      <p class="text-slate-500 text-lg">{t.services.subtitle}</p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {t.services.items.map((service, i) => (
        <div class={`card group hover:border-brand-200 hover:-translate-y-0.5 transition-all duration-200 ${i === 4 ? 'sm:col-span-2 lg:col-span-1' : ''}`}>
          <div class="w-12 h-12 rounded-xl bg-brand-50 flex items-center justify-center text-2xl mb-5 group-hover:bg-brand-100 transition-colors">
            {service.icon}
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">{service.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
