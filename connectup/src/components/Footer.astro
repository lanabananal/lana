---
import { getTranslations, locales, languageLabels } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const year = new Date().getFullYear();
---

<footer style="background: #1A1A1A; color: #9A95A3;">
  <div class="max-w-[1140px] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="md:col-span-2">
        <a href={`/${locale}`} class="inline-block mb-4">
          <img src="/C_COLORIDO.png" alt="ConnectUP" class="h-10 w-auto" />
        </a>
        <p class="text-sm leading-relaxed max-w-xs" style="color: rgba(255,255,255,0.56); font-family: 'Poppins', sans-serif;">{t.footer.tagline}</p>

        <div class="flex items-center gap-3 mt-5">
          <a href="https://www.youtube.com/@Connectupbr" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10);" onmouseover="this.style.background='#8417aa'" onmouseout="this.style.background='rgba(255,255,255,0.06)'">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/theconnectup/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10);" onmouseover="this.style.background='#8417aa'" onmouseout="this.style.background='rgba(255,255,255,0.06)'">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/connectupbr/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 rounded-lg flex items-center justify-center transition-colors" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10);" onmouseover="this.style.background='#8417aa'" onmouseout="this.style.background='rgba(255,255,255,0.06)'">
            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav links -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4" style="font-family: 'Poppins', sans-serif;">{t.footer.linksTitle}</h3>
        <ul class="space-y-2.5">
          <li><a href={`/${locale}`}              class="text-sm transition-colors hover:text-white" style="color: rgba(255,255,255,0.56); font-family: 'Poppins', sans-serif;">{t.footer.links.home}</a></li>
          <li><a href={`/${locale}/about`}        class="text-sm transition-colors hover:text-white" style="color: rgba(255,255,255,0.56); font-family: 'Poppins', sans-serif;">{t.footer.links.about}</a></li>
          <li><a href={`/${locale}/blog`}         class="text-sm transition-colors hover:text-white" style="color: rgba(255,255,255,0.56); font-family: 'Poppins', sans-serif;">{t.footer.links.blog}</a></li>
          <li><a href={`/${locale}/contact`}      class="text-sm transition-colors hover:text-white" style="color: rgba(255,255,255,0.56); font-family: 'Poppins', sans-serif;">{t.footer.links.contact}</a></li>
          <li><a href={`/${locale}/faq`}          class="text-sm transition-colors hover:text-white" style="color: rgba(255,255,255,0.56); font-family: 'Poppins', sans-serif;">{t.footer.links.faq}</a></li>
          <li><a href={`/${locale}/testimonials`} class="text-sm transition-colors hover:text-white" style="color: rgba(255,255,255,0.56); font-family: 'Poppins', sans-serif;">{t.footer.links.testimonials}</a></li>
        </ul>
      </div>

      <!-- Languages -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4" style="font-family: 'Poppins', sans-serif;">{t.footer.languagesTitle}</h3>
        <ul class="space-y-2.5">
          {locales.map(l => (
            <li>
              <a
                href={`/${l}`}
                class={`text-sm transition-colors ${l === locale ? 'font-semibold' : 'hover:text-white'}`}
                style={`color: ${l === locale ? '#07ffd2' : 'rgba(255,255,255,0.56)'}; font-family: 'Poppins', sans-serif;`}
              >
                {languageLabels[l]}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs" style="border-top: 1px solid rgba(255,255,255,0.10); color: rgba(255,255,255,0.40); font-family: 'Poppins', sans-serif;">
      <p>© {year} ConnectUP. {t.footer.rights}</p>
      <p>Made in Paraguay</p>
    </div>
  </div>
</footer>
