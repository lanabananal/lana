---
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section class="relative py-24 overflow-hidden">
  <!-- City background: BW + blur -->
  <div
    class="absolute inset-0 bg-cover bg-center"
    style="background-image: url('https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=1600&q=80'); filter: grayscale(100%) blur(3px); transform: scale(1.05);"
  ></div>
  <!-- Dark overlay -->
  <div class="absolute inset-0" style="background: linear-gradient(135deg, #1A1A1AF2 0%, #5030E5E0 100%);"></div>

  <div class="relative max-w-[1140px] mx-auto px-6">

    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-4" style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.75);">{t.howItWorks.title}</span>
      <h2 class="font-bold text-white mt-2 mb-4" style="font-size: clamp(28px, 4vw, 42px); letter-spacing: -0.02em;">{t.howItWorks.title}</h2>
      <p class="text-lg" style="color: rgba(255,255,255,0.69);">{t.howItWorks.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      <!-- Connector line -->
      <div class="hidden md:block absolute h-px" style="background: rgba(255,255,255,0.15); top: 2.5rem; left: calc(33.333% + 2.5rem); right: calc(33.333% + 2.5rem);"></div>

      {t.howItWorks.steps.map((step) => (
        <div class="flex flex-col items-center text-center group">
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center mb-6 text-white font-semibold text-sm"
            style="background: linear-gradient(135deg, #5030E5, #BB89FF);"
          >
            {step.number}
          </div>
          <h3 class="text-lg font-bold text-white mb-3">{step.title}</h3>
          <p class="leading-relaxed" style="color: rgba(255,255,255,0.69);">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
