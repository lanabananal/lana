---
import { getTranslations } from '../i18n/translations';
interface Props { locale: string; }
const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="contact" class="relative py-20 overflow-hidden" style="background: linear-gradient(135deg, #470050, #8417aa);">
  <div class="absolute top-0 right-0 w-[350px] h-[350px] rounded-full pointer-events-none" style="background: rgba(231,167,241,0.2); filter: blur(80px);"></div>
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] rounded-full pointer-events-none" style="background: rgba(7,255,210,0.1); filter: blur(80px);"></div>

  <div class="relative max-w-[1140px] mx-auto px-6 text-center">
    <h2 style="font-family:'Fraunces',serif;font-size:clamp(1.5rem,4vw,2rem);font-weight:600;color:white;margin-bottom:1rem;">
      Agende uma conversa gratuita de 20 minutos
    </h2>
    <p style="font-family:'DM Sans';font-size:1.05rem;color:rgba(255,255,255,0.8);margin-bottom:2.5rem;font-weight:300;">
      Sem compromisso. Entenda se faz sentido para o seu perfil.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
      <a href="https://calendly.com/lana-theconnectup/aula-demo" target="_blank" rel="noopener noreferrer"
        style="display:inline-flex;align-items:center;gap:8px;background:white;color:#8417aa;font-family:'DM Sans';font-weight:500;padding:14px 28px;border-radius:8px;transition:all 0.2s;"
        onmouseover="this.style.background='#e1a7f1'" onmouseout="this.style.background='white'">
        Agendar agora →
      </a>
      <a href="https://wa.me/5511913062315" target="_blank" rel="noopener noreferrer"
        style="display:inline-flex;align-items:center;gap:8px;border:1.5px solid white;color:white;font-family:'DM Sans';font-weight:500;padding:14px 28px;border-radius:8px;transition:all 0.2s;">
        Falar no WhatsApp
      </a>
    </div>

    <p style="font-family:'DM Sans';font-size:11px;color:rgba(255,255,255,0.55);">
      Consulta de 20 minutos · Gratuita · Sem compromisso
    </p>
  </div>
</section>
