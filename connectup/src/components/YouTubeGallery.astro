---
import { getTranslations } from '../i18n/translations';

interface Props { locale: string; }
const { locale } = Astro.props;
const t = getTranslations(locale);

// ── Add/replace video IDs here ──────────────────────────────────────────────
// Replace VIDEO_ID_2 and VIDEO_ID_3 with real IDs from @Connectupbr
const videos: Record<string, { id: string; title: string }[]> = {
  'pt-br': [
    { id: 'V20XZKEuJkg', title: 'Advogada Paraguaia Responde' },
    { id: 'VIDEO_ID_2',  title: 'Título do vídeo 2' },
    { id: 'VIDEO_ID_3',  title: 'Título do vídeo 3' },
  ],
  'en': [
    { id: 'DvoRPSaVbqg', title: 'Paraguayan Lawyer Answers' },
    { id: 'VIDEO_ID_2',  title: 'Video title 2' },
    { id: 'VIDEO_ID_3',  title: 'Video title 3' },
  ],
  'es': [
    { id: 'DvoRPSaVbqg', title: 'Abogada Paraguaya Responde' },
    { id: 'VIDEO_ID_2',  title: 'Título del video 2' },
    { id: 'VIDEO_ID_3',  title: 'Título del video 3' },
  ],
  'pl': [
    { id: 'DvoRPSaVbqg', title: 'Paragwajska Prawniczka Odpowiada' },
    { id: 'VIDEO_ID_2',  title: 'Tytuł wideo 2' },
    { id: 'VIDEO_ID_3',  title: 'Tytuł wideo 3' },
  ],
};

const labels: Record<string, { tag: string; title: string; cta: string }> = {
  'pt-br': { tag: 'Conteúdo gratuito', title: 'Assista e aprenda mais',         cta: 'Ver canal no YouTube →' },
  'en':    { tag: 'Free content',      title: 'Watch and learn more',           cta: 'See our YouTube channel →' },
  'es':    { tag: 'Contenido gratuito',title: 'Mira y aprende más',             cta: 'Ver canal en YouTube →' },
  'pl':    { tag: 'Darmowe treści',    title: 'Oglądaj i dowiedz się więcej',   cta: 'Zobacz kanał YouTube →' },
};

const list   = videos[locale]  ?? videos['en'];
const label  = labels[locale]  ?? labels['en'];
---

<section style="background:#111118; padding:4rem 1.5rem;">
  <div class="max-w-[1140px] mx-auto">

    <!-- Header -->
    <div class="text-center mb-10">
      <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#07ffd2;margin-bottom:0.5rem;">
        {label.tag}
      </span>
      <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.4rem,3vw,2rem);font-weight:600;color:white;">
        {label.title}
      </h2>
    </div>

    <!-- Video grid -->
    <div class="yt-grid">
      {list.map((v) => (
        <div class="yt-card" data-id={v.id}>
          <!-- Thumbnail -->
          <div class="yt-thumb-wrap" onclick={`loadVideo(this,'${v.id}')`} style="cursor:pointer;">
            <img
              src={`https://img.youtube.com/vi/${v.id}/maxresdefault.jpg`}
              alt={v.title}
              loading="lazy"
              class="yt-thumb"
              onerror="this.src=`https://img.youtube.com/vi/${this.dataset.id}/hqdefault.jpg`"
              data-id={v.id}
            />
            <!-- Play button overlay -->
            <div class="yt-play">
              <svg width="52" height="52" viewBox="0 0 68 48" fill="none">
                <rect width="68" height="48" rx="10" fill="rgba(0,0,0,0.75)"/>
                <polygon points="26,14 26,34 46,24" fill="white"/>
              </svg>
            </div>
          </div>
          <!-- Title -->
          <p style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;color:rgba(255,255,255,0.80);padding:0.75rem 0 0;line-height:1.4;">
            {v.title}
          </p>
        </div>
      ))}
    </div>

    <!-- Channel link -->
    <div class="text-center mt-10">
      <a
        href="https://www.youtube.com/@Connectupbr"
        target="_blank"
        rel="noopener noreferrer"
        style="display:inline-flex;align-items:center;gap:8px;font-family:'Poppins',sans-serif;font-size:0.88rem;font-weight:500;color:#07ffd2;border:1px solid rgba(7,255,210,0.35);padding:10px 22px;border-radius:8px;transition:background 0.2s;"
        onmouseover="this.style.background='rgba(7,255,210,0.08)'"
        onmouseout="this.style.background='transparent'"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#07ffd2">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        {label.cta}
      </a>
    </div>
  </div>
</section>

<style>
.yt-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}
@media (max-width: 768px) {
  .yt-grid { grid-template-columns: 1fr; }
}
@media (min-width: 769px) and (max-width: 1024px) {
  .yt-grid { grid-template-columns: repeat(2, 1fr); }
}

.yt-thumb-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: 10px;
  overflow: hidden;
  background: #1a1a2e;
}
.yt-thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s;
}
.yt-thumb-wrap:hover .yt-thumb { transform: scale(1.03); }

.yt-play {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s;
}
.yt-thumb-wrap:hover .yt-play { opacity: 0.85; }

.yt-card iframe {
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: 10px;
  border: none;
  display: block;
}
</style>

<script>
function loadVideo(wrapper: HTMLElement, id: string) {
  const iframe = document.createElement('iframe');
  iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1`;
  iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
  iframe.allowFullscreen = true;
  iframe.style.cssText = 'width:100%;aspect-ratio:16/9;border-radius:10px;border:none;display:block;';
  wrapper.replaceWith(iframe);
}
</script>
