---
import { getTranslations } from '../i18n/translations';

interface Props { locale: string; }
const { locale } = Astro.props;
const t = getTranslations(locale);

const videos: Record<string, { id: string; title: string }[]> = {
  'pt-br': [
    { id: 'V20XZKEuJkg', title: 'Como funciona o imposto zero no Paraguai?' },
    { id: '0Fs-yh3fKrY',  title: 'O Paraguai ainda vale a pena em 2026?' },
    { id: '16GvSWFb6Os',  title: 'Residência fiscal no Paraguai: o guia completo' },
  ],
  'en': [
    { id: 'DvoRPSaVbqg', title: 'Tax in Paraguay explained by local lawyer' },
    { id: 'o5uv3ztxbHo',  title: 'Your Dubai Tax Residency Is Gone' },
    { id: 'DVZ9vimHTzc',  title: '0% Tax in 2026 — Paraguay explained' },
  ],
  'es': [
    { id: 'DvoRPSaVbqg', title: 'Abogada Paraguaya Responde sobre impuestos' },
    { id: 'o5uv3ztxbHo',  title: 'Tu residencia fiscal en Dubai ya no aplica' },
    { id: 'DVZ9vimHTzc',  title: '0% de impuesto en 2026 — Paraguay' },
  ],
  'pl': [
    { id: 'DvoRPSaVbqg', title: 'Paragwajska Prawniczka Odpowiada o podatkach' },
    { id: 'o5uv3ztxbHo',  title: 'Twoja rezydencja podatkowa w Dubaju wygasła' },
    { id: 'DVZ9vimHTzc',  title: '0% podatku w 2026 — Paragwaj wyjaśniony' },
  ],
};

const labels: Record<string, { tag: string; title: string; cta: string }> = {
  'pt-br': { tag: 'Conteúdo gratuito', title: 'Assista e aprenda mais',         cta: 'Ver canal no YouTube →' },
  'en':    { tag: 'Free content',      title: 'Watch and learn more',           cta: 'See our YouTube channel →' },
  'es':    { tag: 'Contenido gratuito',title: 'Mira y aprende más',             cta: 'Ver canal en YouTube →' },
  'pl':    { tag: 'Darmowe treści',    title: 'Oglądaj i dowiedz się więcej',   cta: 'Zobacz kanał YouTube →' },
};

const list   = videos[locale]  ?? videos['en'];
const label  = labels[locale]  ?? labels['en'];
const uid    = `ytc-${Math.random().toString(36).slice(2,8)}`;
---

<section style="background:#111118; padding:4rem 1.5rem;">
  <div style="max-width:860px;margin:0 auto;">

    <!-- Header -->
    <div class="text-center mb-10">
      <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#07ffd2;margin-bottom:0.5rem;">
        {label.tag}
      </span>
      <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.4rem,3vw,2rem);font-weight:600;color:white;">
        {label.title}
      </h2>
    </div>

    <!-- Carousel -->
    <div class="ytc-wrap" id={uid}>
      <div class="ytc-track" id={`${uid}-track`}>
        {list.map((v, i) => (
          <div class="ytc-slide" data-idx={i}>
            <div class="ytc-thumb-wrap" id={`${uid}-tw-${i}`} data-id={v.id} data-idx={i}>
              <img
                src={`https://img.youtube.com/vi/${v.id}/maxresdefault.jpg`}
                alt={v.title}
                loading="lazy"
                class="ytc-thumb"
                data-id={v.id}
                onerror={`this.onerror=null;this.src='https://img.youtube.com/vi/${v.id}/hqdefault.jpg'`}
              />
              <button class="ytc-play-btn" aria-label="Assistir no YouTube">
                <svg width="56" height="56" viewBox="0 0 68 48" fill="none">
                  <rect width="68" height="48" rx="10" fill="rgba(0,0,0,0.75)"/>
                  <polygon points="26,14 26,34 46,24" fill="white"/>
                </svg>
              </button>
            </div>
            <p class="ytc-title">{v.title}</p>
          </div>
        ))}
      </div>

      <!-- Prev / Next arrows -->
      {list.length > 1 && (
        <>
          <button class="ytc-arrow ytc-prev" id={`${uid}-prev`} aria-label="Anterior">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>
          <button class="ytc-arrow ytc-next" id={`${uid}-next`} aria-label="Próximo">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
        </>
      )}

      <!-- Dot indicators -->
      {list.length > 1 && (
        <div class="ytc-dots" id={`${uid}-dots`}>
          {list.map((_, i) => (
            <button
              class={`ytc-dot${i === 0 ? ' active' : ''}`}
              data-idx={i}
              aria-label={`Slide ${i + 1}`}
            ></button>
          ))}
        </div>
      )}
    </div>

    <!-- Channel link -->
    <div class="text-center mt-10">
      <a
        href="https://www.youtube.com/@Connectupbr"
        target="_blank"
        rel="noopener noreferrer"
        style="display:inline-flex;align-items:center;gap:8px;font-family:'Poppins',sans-serif;font-size:0.88rem;font-weight:500;color:#07ffd2;border:1px solid rgba(7,255,210,0.35);padding:10px 22px;border-radius:8px;transition:background 0.2s;"
        onmouseover="this.style.background='rgba(7,255,210,0.08)'"
        onmouseout="this.style.background='transparent'"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#07ffd2">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        {label.cta}
      </a>
    </div>
  </div>
</section>

<style>
.ytc-wrap {
  position: relative;
  max-width: 640px;
  margin: 0 auto;
}

.ytc-track {
  display: flex;
  overflow: hidden;
}

.ytc-slide {
  flex: 0 0 100%;
  width: 100%;
}

.ytc-thumb-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: 12px;
  overflow: hidden;
  background: #1a1a2e;
  cursor: pointer;
}

.ytc-thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.35s;
}

.ytc-thumb-wrap:hover .ytc-thumb { transform: scale(1.03); }

.ytc-play-btn {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  cursor: pointer;
  opacity: 0.85;
  transition: opacity 0.2s;
}

.ytc-thumb-wrap:hover .ytc-play-btn { opacity: 1; }

.ytc-title {
  font-family: 'Poppins', sans-serif;
  font-size: 0.95rem;
  font-weight: 500;
  color: rgba(255,255,255,0.85);
  padding: 0.9rem 0.25rem 0;
  line-height: 1.45;
  text-align: center;
  margin: 0;
}

/* Arrows */
.ytc-arrow {
  position: absolute;
  top: calc(50% - 1.6rem); /* vertically centered on the image area */
  transform: translateY(-50%);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid rgba(7,255,210,0.3);
  background: rgba(17,17,24,0.85);
  color: #07ffd2;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s;
  z-index: 2;
}
.ytc-arrow:hover { background: rgba(7,255,210,0.12); border-color: rgba(7,255,210,0.7); }
.ytc-prev { left: -52px; }
.ytc-next { right: -52px; }

/* Dots */
.ytc-dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 1.1rem;
}
.ytc-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.2);
  cursor: pointer;
  transition: background 0.25s, transform 0.2s;
  padding: 0;
}
.ytc-dot.active {
  background: #07ffd2;
  transform: scale(1.25);
}

/* iframe inside slide */
.ytc-slide iframe {
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: 12px;
  border: none;
  display: block;
}

/* Responsive: hide arrows on narrow screens, show dots for navigation */
@media (max-width: 780px) {
  .ytc-prev { left: -4px; }
  .ytc-next { right: -4px; }
  .ytc-arrow { background: rgba(17,17,24,0.92); }
}
</style>

<script is:inline define:vars={{ uid, total: list.length, videos: list }}>
(function() {
  var cur = 0;

  var track  = document.getElementById(uid + '-track');
  var prev   = document.getElementById(uid + '-prev');
  var next   = document.getElementById(uid + '-next');
  var dotsEl = document.getElementById(uid + '-dots');

  function goTo(idx) {
    cur = (idx + total) % total;
    track.style.transform = 'translateX(-' + (cur * 100) + '%)';
    track.style.transition = 'transform 0.4s cubic-bezier(.4,0,.2,1)';
    // update dots
    if (dotsEl) {
      dotsEl.querySelectorAll('.ytc-dot').forEach(function(d, i) {
        d.classList.toggle('active', i === cur);
      });
    }
  }

  if (prev) prev.addEventListener('click', function() { goTo(cur - 1); });
  if (next) next.addEventListener('click', function() { goTo(cur + 1); });

  if (dotsEl) {
    dotsEl.querySelectorAll('.ytc-dot').forEach(function(d) {
      d.addEventListener('click', function() { goTo(parseInt(d.dataset.idx)); });
    });
  }

  // Click thumbnail → play inline
  document.querySelectorAll('[id^="' + uid + '-tw-"]').forEach(function(tw) {
    tw.addEventListener('click', function() {
      var id = tw.dataset.id;
      var iframe = document.createElement('iframe');
      iframe.src = 'https://www.youtube.com/embed/' + id + '?autoplay=1';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'width:100%;aspect-ratio:16/9;border-radius:12px;border:none;display:block;';
      tw.replaceWith(iframe);
    });
  });

  // Touch swipe support
  var touchStartX = 0;
  track.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', function(e) {
    var dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 40) goTo(dx < 0 ? cur + 1 : cur - 1);
  });
})();
</script>
