---
---
<section style="background:#f7f4fa;padding:5rem 1.5rem;">
  <div style="max-width:1140px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:3rem;">
      <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#795389;">Comparativo</span>
      <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.6rem,3.5vw,2.2rem);font-weight:600;margin-top:0.5rem;">Brasil vs Paraguai</h2>
    </div>

    <div style="max-width:800px;margin:0 auto;display:flex;flex-direction:column;gap:1.5rem;">
      {[
        { label:'IRPF',             br: { pct:27.5, w:100 }, py: { pct:10,   w:36,  label:'10%' } },
        { label:'Dividendos',       br: { pct:22.5, w:82  }, py: { pct:0,    w:0,   label:'0% isento' } },
        { label:'Ganho de capital', br: { pct:22.5, w:82  }, py: { pct:0,    w:0,   label:'0% isento' } },
        { label:'Renda exterior',   br: { pct:27.5, w:100 }, py: { pct:0,    w:0,   label:'0% isento' } },
        { label:'Previdência',      br: { pct:14,   w:51  }, py: { pct:null, w:0,   label:'Opcional' } },
      ].map((row) => (
        <div>
          <div style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;margin-bottom:8px;color:#333;">{row.label}</div>
          <div style="display:flex;flex-direction:column;gap:6px;">
            <div style="display:flex;align-items:center;gap:10px;">
              <span style="font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;color:#795389;width:60px;flex-shrink:0;">Brasil</span>
              <div style="flex:1;height:32px;background:rgba(128,128,128,0.1);border-radius:6px;overflow:hidden;">
                <div style={`width:${row.br.w}%;height:100%;background:linear-gradient(90deg,#470050,#8417aa);border-radius:6px;display:flex;align-items:center;padding:0 12px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:600;color:white;`}>{row.br.pct}%</div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;">
              <span style="font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;color:#795389;width:60px;flex-shrink:0;">Paraguai</span>
              <div style="flex:1;height:32px;background:rgba(128,128,128,0.1);border-radius:6px;overflow:hidden;">
                {row.py.w > 0 ? (
                  <div style={`width:${row.py.w}%;height:100%;background:rgba(7,255,210,0.15);border:1px dashed rgba(7,255,210,0.5);border-radius:6px;display:flex;align-items:center;padding:0 12px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:600;color:#07ffd2;`}>{row.py.label}</div>
                ) : (
                  <div style="height:100%;background:rgba(7,255,210,0.08);border:1px dashed rgba(7,255,210,0.3);border-radius:6px;display:flex;align-items:center;padding:0 12px;font-family:'Poppins',sans-serif;font-size:13px;font-weight:600;color:#07ffd2;">{row.py.label}</div>
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div style="text-align:center;margin-top:3rem;">
      <a href="https://wa.me/5511913062315" target="_blank" rel="noopener noreferrer" class="btn-primary">Quero pagar menos imposto</a>
    </div>
  </div>
</section>
