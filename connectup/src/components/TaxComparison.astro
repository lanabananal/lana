---
// PT-BR only section
---
<section class="py-20" style="background: #f7f4fa;">
  <div class="max-w-[1140px] mx-auto px-6">

    <div class="text-center mb-14">
      <span class="section-tag">Por que sair do Brasil fiscalmente?</span>
      <h2 style="font-family: 'Fraunces', serif; font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 600; margin-top: 0.5rem;">Brasil vs. Paraguai: compare os impostos</h2>
    </div>

    <!-- Bar chart -->
    <div class="grid grid-cols-1 gap-6 max-w-3xl mx-auto mb-14">
      {[
        { label: 'IRPF máximo', br: 27.5, py: 10, brColor: '#e63946', pyColor: '#8417aa' },
        { label: 'Dividendos', br: 22.5, py: 0, brColor: '#e63946', pyColor: '#07ffd2' },
        { label: 'Ganho de capital', br: 22.5, py: 0, brColor: '#e63946', pyColor: '#07ffd2' },
        { label: 'Renda do exterior', br: 27.5, py: 0, brColor: '#e63946', pyColor: '#07ffd2' },
      ].map(row => (
        <div>
          <p style="font-family: 'DM Sans'; font-size: 0.85rem; font-weight: 500; margin-bottom: 6px;">{row.label}</p>
          <div class="flex gap-2 items-center">
            <span style="font-size: 0.75rem; width: 60px; text-align: right; font-family: 'DM Sans'; color: #555;">Brasil</span>
            <div style={`height: 24px; width: ${row.br * 3}px; background: ${row.brColor}; border-radius: 4px; display: flex; align-items: center; padding-left: 8px;`}>
              <span style="color: white; font-size: 0.7rem; font-family: 'DM Sans'; font-weight: 500;">{row.br}%</span>
            </div>
          </div>
          <div class="flex gap-2 items-center mt-1">
            <span style="font-size: 0.75rem; width: 60px; text-align: right; font-family: 'DM Sans'; color: #555;">Paraguai</span>
            <div style={`height: 24px; width: ${Math.max(row.py * 3, 40)}px; background: ${row.pyColor}; border-radius: 4px; display: flex; align-items: center; padding-left: 8px;`}>
              <span style="color: ${row.py === 0 ? '#000' : 'white'}; font-size: 0.7rem; font-family: 'DM Sans'; font-weight: 500;">{row.py === 0 ? '0% — isento' : `${row.py}%`}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Legend -->
    <div class="flex justify-center gap-6 mb-14">
      <div class="flex items-center gap-2"><div style="width:12px;height:12px;background:#e63946;border-radius:2px;"></div><span style="font-family:'DM Sans';font-size:0.8rem;">Brasil</span></div>
      <div class="flex items-center gap-2"><div style="width:12px;height:12px;background:#8417aa;border-radius:2px;"></div><span style="font-family:'DM Sans';font-size:0.8rem;">Paraguai</span></div>
    </div>

    <!-- Table -->
    <div class="max-w-2xl mx-auto mb-12 overflow-x-auto">
      <table style="width:100%;border-collapse:collapse;font-family:'DM Sans';font-size:0.875rem;">
        <thead>
          <tr style="background:#8417aa;color:white;">
            <th style="padding:10px 16px;text-align:left;border-radius:8px 0 0 0;">Imposto</th>
            <th style="padding:10px 16px;text-align:center;">Brasil</th>
            <th style="padding:10px 16px;text-align:center;border-radius:0 8px 0 0;">Paraguai</th>
          </tr>
        </thead>
        <tbody>
          {[
            ['IRPF máximo','27,5%','10%'],
            ['Dividendos','15–22,5%','0%'],
            ['Ganho de capital','até 22,5%','0%'],
            ['Renda do exterior','Tributada','Isenta'],
            ['Previdência','até 14%','Opcional'],
          ].map((row, i) => (
            <tr style={`background:${i%2===0?'white':'#f7f4fa'};`}>
              <td style="padding:10px 16px;color:#333;">{row[0]}</td>
              <td style="padding:10px 16px;text-align:center;color:#e63946;font-weight:500;">{row[1]}</td>
              <td style="padding:10px 16px;text-align:center;color:#8417aa;font-weight:500;">{row[2]}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="text-center">
      <a href="https://wa.me/5511913062315" target="_blank" rel="noopener noreferrer" class="btn-primary">Quero pagar menos imposto</a>
    </div>
  </div>
</section>
