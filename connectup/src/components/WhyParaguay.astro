---
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const topColors = ['#07ffd2', '#8417aa', '#07ffd2', '#8417aa', '#07ffd2', '#8417aa'];
---

<section class="py-20" style="background: #F5F5F5;">
  <div class="max-w-[1140px] mx-auto px-6">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left -->
      <div>
        <span class="section-tag">Paraguay</span>
        <h2 class="font-bold text-dark mt-2 mb-4" style="font-size: clamp(28px, 4vw, 42px); letter-spacing: -0.02em;">{t.why.title}</h2>
        <p class="text-lg mb-10" style="color: #9A95A3;">{t.why.subtitle}</p>
        <a href="https://web.whatsapp.com/send?phone=5511913062315" target="_blank" rel="noopener noreferrer" class="btn-primary">
          {t.cta.button}
        </a>
      </div>

      <!-- Right: benefits grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {t.why.items.map((item, i) => (
          <div
            class="bg-white rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-md"
            style={`border: 1px solid #E8E4ED; border-top: 3px solid ${topColors[i]};`}
          >
            <h3 class="font-bold text-dark text-sm mb-1">{item.title}</h3>
            <p class="text-xs leading-relaxed" style="color: #9A95A3;">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
