---
import { getCollection } from 'astro:content';
import { getTranslations } from '../i18n/translations';

interface Props { locale: string; }
const { locale } = Astro.props;
const t = getTranslations(locale);

const langMap: Record<string, string> = {
  'pt-br': 'pt-br',
  'en': 'en',
  'es': 'es',
  'pl': 'pl',
};
const lang = langMap[locale] ?? 'en';

let posts: any[] = [];
try {
  const allPosts = await getCollection('blog');
  posts = allPosts
    .filter((p: any) => p.id.startsWith(lang + '-') || p.data.lang === lang)
    .sort((a: any, b: any) => new Date(b.data.pubDate ?? b.data.date ?? 0).getTime() - new Date(a.data.pubDate ?? a.data.date ?? 0).getTime());
} catch(e) {
  posts = [];
}

const bc = (t as any).blogCarousel ?? { tag: 'Blog', title: 'Latest posts', readMore: 'Read', viewAll: 'View all' };
---

{posts.length > 0 && (
<section style="padding:5rem 1.5rem;background:white;">
  <div style="max-width:1140px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#795389;">{bc.tag}</span>
      <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.6rem,3.5vw,2.2rem);font-weight:600;margin-top:0.5rem;">{bc.title}</h2>
    </div>

    <!-- Carousel wrapper -->
    <div style="position:relative;">
      <!-- Posts grid — all rendered, JS shows/hides by page -->
      <div id="blog-posts-grid" class="blog-carousel-track">
        {posts.map((post: any, index: number) => (
          <a
            href={`/${locale}/blog/${post.data.postSlug}`}
            class="blog-text-card"
            data-index={index}
            style={index >= 3 ? 'display:none;' : ''}
          >
            {post.data.tags?.[0] && (
              <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:10px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:#07ffd2;margin-bottom:8px;">{post.data.tags[0]}</span>
            )}
            <h3 style="font-family:'Poppins',sans-serif;font-size:1rem;font-weight:600;color:white;line-height:1.4;margin-bottom:10px;">{post.data.title}</h3>
            {post.data.description && (
              <p style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:300;color:rgba(255,255,255,0.75);line-height:1.6;margin-bottom:14px;">{post.data.description}</p>
            )}
            <span style="font-family:'Poppins',sans-serif;font-size:0.8rem;font-weight:500;color:#07ffd2;">{bc.readMore} →</span>
          </a>
        ))}
      </div>

      <!-- Navigation arrows -->
      {posts.length > 3 && (
        <div style="display:flex;justify-content:center;align-items:center;gap:1rem;margin-top:2rem;">
          <button id="blog-prev" aria-label="Previous" style="width:40px;height:40px;border-radius:50%;border:1.5px solid #8417aa;background:transparent;color:#8417aa;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;opacity:0.4;" disabled>
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <span id="blog-page-indicator" style="font-family:'Poppins',sans-serif;font-size:0.82rem;color:#795389;">1 / {Math.ceil(posts.length / 3)}</span>
          <button id="blog-next" aria-label="Next" style="width:40px;height:40px;border-radius:50%;border:1.5px solid #8417aa;background:transparent;color:#8417aa;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      )}
    </div>

    <div style="text-align:center;margin-top:2rem;">
      <a href={`/${locale}/blog`} style="display:inline-flex;align-items:center;gap:8px;border:1.5px solid #8417aa;color:#8417aa;font-family:'Poppins',sans-serif;font-weight:500;padding:12px 24px;border-radius:8px;transition:all 0.2s;" onmouseover="this.style.background='#f7f4fa'" onmouseout="this.style.background='transparent'">
        {bc.viewAll}
      </a>
    </div>
  </div>
</section>
)}

<style>
.blog-carousel-track {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}
@media (max-width: 768px) {
  .blog-carousel-track { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .blog-carousel-track { grid-template-columns: 1fr; }
}
.blog-text-card {
  display: block;
  text-decoration: none;
  background: linear-gradient(135deg, #470050, #8417aa);
  border-radius: 12px;
  padding: 1.5rem;
  min-height: 200px;
  transition: transform 0.2s, box-shadow 0.2s;
}
.blog-text-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(132,23,170,0.3);
}
</style>

<script>
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.blog-text-card'));
  const prevBtn = document.getElementById('blog-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('blog-next') as HTMLButtonElement | null;
  const indicator = document.getElementById('blog-page-indicator');
  const perPage = 3;
  let currentPage = 0;
  const totalPages = Math.ceil(cards.length / perPage);

  function showPage(page: number) {
    cards.forEach((card, i) => {
      card.style.display = (i >= page * perPage && i < (page + 1) * perPage) ? '' : 'none';
    });
    if (indicator) indicator.textContent = `${page + 1} / ${totalPages}`;
    if (prevBtn) { prevBtn.disabled = page === 0; prevBtn.style.opacity = page === 0 ? '0.4' : '1'; }
    if (nextBtn) { nextBtn.disabled = page >= totalPages - 1; nextBtn.style.opacity = page >= totalPages - 1 ? '0.4' : '1'; }
  }

  prevBtn?.addEventListener('click', () => { if (currentPage > 0) { currentPage--; showPage(currentPage); } });
  nextBtn?.addEventListener('click', () => { if (currentPage < totalPages - 1) { currentPage++; showPage(currentPage); } });
</script>
