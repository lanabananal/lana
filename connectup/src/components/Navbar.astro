---
import { getTranslations, locales, languageLabels, languageShort } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

// Strip locale prefix to get the path segment (e.g. /en/about → /about)
const rawPath = Astro.url.pathname.replace(/^\/(en|pt-br|pl|es)/, '') || '/';

function localePath(targetLocale: string, path: string) {
  return `/${targetLocale}${path === '/' ? '' : path}` || `/${targetLocale}`;
}
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-100">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href={`/${locale}`} class="flex items-center gap-2 shrink-0">
      <span class="text-brand-600 font-black text-xl tracking-tight">Connect<span class="text-slate-900">Up</span></span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-1">
      <a href={`/${locale}`}       class="nav-link">{t.nav.home}</a>
      <a href={`/${locale}/about`} class="nav-link">{t.nav.about}</a>
      <a href={`/${locale}/blog`}  class="nav-link">{t.nav.blog}</a>
      <a href={`/${locale}#contact`} class="nav-link">{t.nav.contact}</a>
    </div>

    <!-- Right side: lang switcher + CTA -->
    <div class="hidden md:flex items-center gap-3">

      <!-- Language Switcher -->
      <div class="relative" id="lang-switcher">
        <button
          id="lang-btn"
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-slate-200 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors"
          aria-haspopup="true"
          aria-expanded="false"
        >
          <span>{languageLabels[locale as keyof typeof languageLabels] ?? locale.toUpperCase()}</span>
          <svg class="w-3.5 h-3.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div
          id="lang-menu"
          class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-slate-100 py-1 z-50 hidden"
          role="menu"
        >
          {locales.map(l => (
            <a
              href={localePath(l, rawPath)}
              class={`flex items-center gap-2 px-4 py-2.5 text-sm hover:bg-slate-50 transition-colors ${l === locale ? 'text-brand-600 font-semibold bg-brand-50' : 'text-slate-700'}`}
              role="menuitem"
            >
              {languageLabels[l]}
            </a>
          ))}
        </div>
      </div>

      <a href={`/${locale}#contact`} class="btn-primary text-sm py-2">{t.nav.getStarted}</a>
    </div>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors" aria-label="Menu">
      <svg id="icon-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100 bg-white">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      <a href={`/${locale}`}         class="block px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-50 font-medium">{t.nav.home}</a>
      <a href={`/${locale}/about`}   class="block px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-50 font-medium">{t.nav.about}</a>
      <a href={`/${locale}/blog`}    class="block px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-50 font-medium">{t.nav.blog}</a>
      <a href={`/${locale}#contact`} class="block px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-50 font-medium">{t.nav.contact}</a>

      <div class="pt-3 border-t border-slate-100">
        <p class="px-4 text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Language</p>
        {locales.map(l => (
          <a
            href={localePath(l, rawPath)}
            class={`block px-4 py-2.5 rounded-lg text-sm font-medium ${l === locale ? 'text-brand-600 bg-brand-50' : 'text-slate-600 hover:bg-slate-50'}`}
          >
            {languageLabels[l]}
          </a>
        ))}
      </div>

      <div class="pt-3">
        <a href={`/${locale}#contact`} class="btn-primary w-full text-center">{t.nav.getStarted}</a>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link {
    @apply px-3 py-2 rounded-lg text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-50 transition-colors;
  }
</style>

<script>
  // Language dropdown
  const langBtn  = document.getElementById('lang-btn');
  const langMenu = document.getElementById('lang-menu');
  if (langBtn && langMenu) {
    langBtn.addEventListener('click', () => {
      const isOpen = langMenu.classList.toggle('hidden') === false;
      langBtn.setAttribute('aria-expanded', String(isOpen));
    });
    document.addEventListener('click', (e) => {
      if (!langBtn.contains(e.target as Node) && !langMenu.contains(e.target as Node)) {
        langMenu.classList.add('hidden');
        langBtn.setAttribute('aria-expanded', 'false');
      }
    });
  }

  // Mobile menu
  const mobileBtn   = document.getElementById('mobile-menu-btn');
  const mobileMenu  = document.getElementById('mobile-menu');
  const iconOpen    = document.getElementById('icon-open');
  const iconClose   = document.getElementById('icon-close');
  if (mobileBtn && mobileMenu) {
    mobileBtn.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.toggle('hidden') === false;
      iconOpen?.classList.toggle('hidden', isOpen);
      iconClose?.classList.toggle('hidden', !isOpen);
    });
  }
</script>
