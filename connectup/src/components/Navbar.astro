---
import { getTranslations, locales, languageLabels, languageShort } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const rawPath = Astro.url.pathname.replace(/^\/(en|pt-br|pl|es)/, '') || '/';

function localePath(targetLocale: string, path: string) {
  return `/${targetLocale}${path === '/' ? '' : path}` || `/${targetLocale}`;
}
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background: rgba(255,255,255,0.97); backdrop-filter: blur(20px); border-bottom: 1px solid transparent;">
  <nav class="max-w-[1140px] mx-auto px-6 h-[88px] flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href={`/${locale}`} class="flex flex-col items-center shrink-0">
      <img src="/C_COLORIDO.png" alt="ConnectUP" class="h-14 w-auto" />
      <span style="font-family:'Poppins',sans-serif;font-size:11px;font-weight:600;letter-spacing:0.08em;color:#8417aa;margin-top:2px;">ConnectUP</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-1">
      <a href={`/${locale}`} class="nav-link">{t.nav.home}</a>

      <!-- Carreira dropdown -->
      <div class="relative" id="career-dropdown">
        <button id="career-btn" class="nav-link flex items-center gap-1" aria-haspopup="true" aria-expanded="false">
          {t.nav.services ?? 'Carreira'}
          <svg class="w-3 h-3 text-[#9A95A3]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="career-menu" class="absolute left-0 mt-1 w-60 bg-white rounded-xl py-1 z-50 hidden" role="menu" style="box-shadow:0 8px 32px rgba(0,0,0,0.12);border:1px solid #E8E4ED;">
          <a href={`/${locale}/comunicacao-profissional`} class="flex items-center gap-2 px-4 py-2.5 text-sm text-[#2A2A2A] hover:bg-offwhite transition-colors" role="menuitem">
            <span style="color:#8417aa;">✦</span> {t.nav.comunicacaoProfissional ?? 'Comunicação Profissional'}
          </a>
          <a href={`/${locale}/cv-linkedin`} class="flex items-center gap-2 px-4 py-2.5 text-sm text-[#2A2A2A] hover:bg-offwhite transition-colors" role="menuitem">
            <span style="color:#e1a7f1;">✦</span> {t.nav.cvLinkedin ?? 'CV & LinkedIn'}
          </a>
        </div>
      </div>

      <!-- Planejamento Financeiro dropdown -->
      <div class="relative" id="finance-dropdown">
        <button id="finance-btn" class="nav-link flex items-center gap-1" aria-haspopup="true" aria-expanded="false">
          {t.nav.financeiro ?? 'Planejamento Financeiro'}
          <svg class="w-3 h-3 text-[#9A95A3]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div id="finance-menu" class="absolute left-0 mt-1 w-64 bg-white rounded-xl py-1 z-50 hidden" role="menu" style="box-shadow:0 8px 32px rgba(0,0,0,0.12);border:1px solid #E8E4ED;">
          <a href={`/${locale}/planejamento-financeiro`} class="flex items-center gap-2 px-4 py-2.5 text-sm text-[#2A2A2A] hover:bg-offwhite transition-colors" role="menuitem">
            <span style="color:#07ffd2;">✦</span> {t.nav.planejamentoInternacional ?? 'Planejamento Financeiro Internacional'}
          </a>
          <a href={`/${locale}/planejamento-fiscal`} class="flex items-center gap-2 px-4 py-2.5 text-sm text-[#2A2A2A] hover:bg-offwhite transition-colors" role="menuitem">
            <span style="color:#07ffd2;">✦</span> {t.nav.planejamentoFiscal ?? 'Planejamento Fiscal no Paraguai'}
          </a>
        </div>
      </div>

      <a href={`/${locale}/blog`}    class="nav-link">{t.nav.blog}</a>
      <a href={`/${locale}/contact`} class="nav-link">{t.nav.contact}</a>
    </div>

    <!-- Right: lang switcher + CTA -->
    <div class="hidden md:flex items-center gap-3">

      <!-- Language Switcher -->
      <div class="relative" id="lang-switcher">
        <button
          id="lang-btn"
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-[#E8E4ED] text-sm font-medium text-[#2A2A2A] hover:bg-offwhite transition-colors"
          aria-haspopup="true"
          aria-expanded="false"
        >
          <span>{languageShort[locale as keyof typeof languageShort] ?? locale.toUpperCase()}</span>
          <svg class="w-3.5 h-3.5 text-[#9A95A3]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div
          id="lang-menu"
          class="absolute right-0 mt-2 w-48 bg-white rounded-xl py-1 z-50 hidden"
          role="menu"
          style="box-shadow: 0 8px 32px rgba(0,0,0,0.12); border: 1px solid #E8E4ED;"
        >
          {locales.map(l => (
            <a
              href={localePath(l, rawPath)}
              class={`flex items-center gap-2 px-4 py-2.5 text-sm hover:bg-offwhite transition-colors ${l === locale ? 'text-brand font-semibold' : 'text-[#2A2A2A]'}`}
              role="menuitem"
            >
              {languageLabels[l]}
            </a>
          ))}
        </div>
      </div>

      <a href="https://wa.me/5511913062315" target="_blank" rel="noopener noreferrer" class="btn-primary text-sm py-2 px-5">{t.nav.getStarted}</a>
    </div>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-offwhite transition-colors" aria-label="Menu">
      <svg id="icon-open" class="w-5 h-5 text-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-5 h-5 text-dark hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-[#E8E4ED]" style="box-shadow: 0 8px 32px rgba(0,0,0,0.08);">
    <div class="max-w-[1140px] mx-auto px-6 py-4 space-y-1">
      <a href={`/${locale}`} class="block px-4 py-2.5 rounded-xl text-dark hover:bg-offwhite font-medium text-sm">{t.nav.home}</a>

      <p class="px-4 pt-2 pb-1 text-xs font-semibold text-[#9A95A3] uppercase tracking-wider">{t.nav.services ?? 'Carreira'}</p>
      <a href={`/${locale}/comunicacao-profissional`} class="block px-4 py-2.5 rounded-xl text-dark hover:bg-offwhite font-medium text-sm pl-6">{t.nav.comunicacaoProfissional ?? 'Comunicação Profissional'}</a>
      <a href={`/${locale}/cv-linkedin`}              class="block px-4 py-2.5 rounded-xl text-dark hover:bg-offwhite font-medium text-sm pl-6">{t.nav.cvLinkedin ?? 'CV & LinkedIn'}</a>

      <p class="px-4 pt-2 pb-1 text-xs font-semibold text-[#9A95A3] uppercase tracking-wider">{t.nav.financeiro ?? 'Planejamento Financeiro'}</p>
      <a href={`/${locale}/planejamento-financeiro`} class="block px-4 py-2.5 rounded-xl text-dark hover:bg-offwhite font-medium text-sm pl-6">{t.nav.planejamentoInternacional ?? 'Planejamento Financeiro Internacional'}</a>
      <a href={`/${locale}/planejamento-fiscal`}     class="block px-4 py-2.5 rounded-xl text-dark hover:bg-offwhite font-medium text-sm pl-6">{t.nav.planejamentoFiscal ?? 'Planejamento Fiscal no Paraguai'}</a>

      <a href={`/${locale}/blog`}    class="block px-4 py-2.5 rounded-xl text-dark hover:bg-offwhite font-medium text-sm">{t.nav.blog}</a>
      <a href={`/${locale}/contact`} class="block px-4 py-2.5 rounded-xl text-dark hover:bg-offwhite font-medium text-sm">{t.nav.contact}</a>

      <div class="pt-3 border-t border-[#E8E4ED]">
        <p class="px-4 text-xs font-semibold text-[#9A95A3] uppercase tracking-wider mb-2">{t.nav.language}</p>
        {locales.map(l => (
          <a
            href={localePath(l, rawPath)}
            class={`block px-4 py-2.5 rounded-xl text-sm font-medium ${l === locale ? 'text-brand bg-brand/5' : 'text-dark hover:bg-offwhite'}`}
          >
            {languageLabels[l]}
          </a>
        ))}
      </div>

      <div class="pt-3">
        <a href="https://wa.me/5511913062315" target="_blank" rel="noopener noreferrer" class="btn-primary w-full text-center text-sm">{t.nav.getStarted}</a>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link {
    @apply px-3 py-2 rounded-lg text-sm font-medium text-[#2A2A2A] hover:text-brand transition-colors relative;
  }
  .nav-link::after {
    content: '';
    @apply absolute bottom-0 left-3 right-3 h-0.5 bg-brand scale-x-0 transition-transform duration-200;
  }
  .nav-link:hover::after {
    @apply scale-x-100;
  }
</style>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.style.setProperty('border-bottom-color', '#E8E4ED');
    } else {
      navbar?.style.setProperty('border-bottom-color', 'transparent');
    }
  });

  // Generic dropdown factory
  function initDropdown(btnId: string, menuId: string, stopProp = true) {
    const btn  = document.getElementById(btnId);
    const menu = document.getElementById(menuId);
    if (!btn || !menu) return;
    btn.addEventListener('click', (e) => {
      if (stopProp) e.stopPropagation();
      // Close all other dropdowns first
      document.querySelectorAll('[data-dropdown-menu]').forEach(el => {
        if (el !== menu) el.classList.add('hidden');
      });
      const isOpen = menu.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(isOpen));
    });
    menu.setAttribute('data-dropdown-menu', '');
    document.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    });
  }

  initDropdown('career-btn',  'career-menu');
  initDropdown('finance-btn', 'finance-menu');

  // Language dropdown
  const langBtn  = document.getElementById('lang-btn');
  const langMenu = document.getElementById('lang-menu');
  if (langBtn && langMenu) {
    langBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      document.querySelectorAll('[data-dropdown-menu]').forEach(el => el.classList.add('hidden'));
      const isOpen = langMenu.classList.toggle('hidden') === false;
      langBtn.setAttribute('aria-expanded', String(isOpen));
    });
    document.addEventListener('click', (e) => {
      if (!langBtn.contains(e.target as Node) && !langMenu.contains(e.target as Node)) {
        langMenu.classList.add('hidden');
        langBtn.setAttribute('aria-expanded', 'false');
      }
    });
  }

  // Mobile menu
  const mobileBtn  = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen   = document.getElementById('icon-open');
  const iconClose  = document.getElementById('icon-close');
  if (mobileBtn && mobileMenu) {
    mobileBtn.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.toggle('hidden') === false;
      iconOpen?.classList.toggle('hidden', isOpen);
      iconClose?.classList.toggle('hidden', !isOpen);
    });
  }
</script>
