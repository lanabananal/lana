---
import { getTranslations } from '../i18n/translations';
interface Props { locale: string; }
const { locale } = Astro.props;
const t = getTranslations(locale);
const videoId = locale === 'pt-br' ? 'V20XZKEuJkg' : 'DvoRPSaVbqg';

const qaCards = t.video.qa;
---

<section class="py-20 bg-white">
  <div class="max-w-[1140px] mx-auto px-6">

    <!-- Label -->
    <div class="text-center mb-10">
      <span class="section-tag">{t.video.label}</span>
    </div>

    <!-- Video -->
    <div class="flex justify-center mb-12">
      <div class="relative w-full max-w-[760px]" style="aspect-ratio: 16/9;">
        <iframe
          src={`https://www.youtube.com/embed/${videoId}`}
          title="ConnectUP Q&A"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen loading="lazy"
          class="absolute inset-0 w-full h-full"
          style="border-radius: 16px; box-shadow: 0 16px 48px rgba(0,0,0,0.15);"
        ></iframe>
      </div>
    </div>

    <!-- Q&A cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
      {qaCards.map((item) => (
        <div class="rounded-xl p-5" style="background: #f7f4fa; border: 1px solid #dfdede;">
          <div class="flex items-start gap-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#07ffd2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
            <div>
              <p style="font-family: 'Poppins', sans-serif; font-weight: 500; font-size: 0.85rem; color: #8417aa;" class="mb-1">{item.q}</p>
              <p style="font-family: 'Poppins', sans-serif; font-size: 0.82rem; color: #555; line-height: 1.5;">{item.a}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust line -->
    <p class="text-center text-sm italic mb-8" style="color: #795389; font-family: 'Poppins', sans-serif;">{t.video.trust}</p>

    <!-- CTA -->
    <div class="text-center">
      <a href="https://wa.me/5511913062315" target="_blank" rel="noopener noreferrer" class="btn-primary">
        {t.video.cta}
      </a>
    </div>
  </div>
</section>
