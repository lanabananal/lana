---
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const videoId = locale === 'pt-br' ? 'V20XZKEuJkg' : 'DvoRPSaVbqg';
---

<section class="py-20 bg-slate-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">{t.video.title}</h2>
    <p class="text-slate-500 text-lg mb-10">{t.video.subtitle}</p>

    <div class="flex justify-center">
      <!-- 9:16 aspect ratio container for YouTube Short -->
      <div class="relative w-full max-w-xs" style="aspect-ratio: 9/16;">
        <iframe
          src={`https://www.youtube.com/embed/${videoId}`}
          title="ConnectUp"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="absolute inset-0 w-full h-full rounded-2xl shadow-xl"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </div>
</section>
