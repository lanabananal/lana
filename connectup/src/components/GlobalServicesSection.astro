const l = labels[locale] ?? labels['en'];
---

<section id="services-overview" style="background:#f7f4fa; padding:5rem 1.5rem;">
  <div style="max-width:1140px; margin:0 auto;">
    <div style="text-align:center; margin-bottom:3rem;">
      <span style="display:inline-block; font-family:'Poppins',sans-serif; font-size:11px; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:#795389; margin-bottom:0.5rem;">{l.tag}</span>
      <h2 style="font-family:'Poppins',sans-serif; font-size:clamp(1.6rem,3.5vw,2.2rem); font-weight:600; color:#1a1a1a; margin-bottom:0.75rem;">{l.title}</h2>
      <p style="font-family:'Poppins',sans-serif; font-size:0.95rem; font-weight:300; color:#555; max-width:560px; margin:0 auto; line-height:1.7;">{l.subtitle}</p>
    </div>

    <div class="svc-grid">
      {l.services.map((svc: any) => (
        <a href={svc.href} class="svc-card" style={`--accent: ${svc.color};`}>
          <div class="svc-icon-wrap" style={`background:${svc.color}18; border:1px solid ${svc.color}30;`}>
            <svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke={svc.color} stroke-width="1.5" set:html={svc.icon}></svg>
          </div>
          <h3 style="font-family:'Poppins',sans-serif; font-size:1.05rem; font-weight:600; color:#1a1a1a; margin-bottom:0.6rem; line-height:1.3;">{svc.title}</h3>
          <p style="font-family:'Poppins',sans-serif; font-size:0.85rem; font-weight:300; color:#555; line-height:1.7; flex:1;">{svc.desc}</p>
          <div style={`font-family:'Poppins',sans-serif; font-size:0.85rem; font-weight:600; color:${svc.color}; margin-top:1.25rem;`}>{svc.cta}</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.svc-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
  align-items: stretch;
}
.svc-card {
  background: white;
  border: 1px solid #e8e4ed;
  border-radius: 16px;
  padding: 2rem 1.75rem;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  height: 100%;
}
.svc-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(132,23,170,0.12);
  border-color: var(--accent);
}
.svc-icon-wrap {
  width: 52px;
  height: 52px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
  flex-shrink: 0;
}
@media (max-width: 640px) {
  .svc-grid { grid-template-columns: 1fr; }
}
@media (min-width: 641px) and (max-width: 1024px) {
  .svc-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
