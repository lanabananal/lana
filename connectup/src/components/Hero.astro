---
import { getTranslations } from '../i18n/translations';
interface Props { locale: string; }
const { locale } = Astro.props;
const t = getTranslations(locale);

const ctaHref = 'https://wa.me/5511913062315';
const secondaryHref = `#services-overview`;
---

<section class="relative overflow-hidden pt-[120px] pb-24" style="background: linear-gradient(165deg, #1A1A1AF0 0%, #1a0a2eE8 40%, #8417aaCC 100%);">
  <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] rounded-full pointer-events-none" style="background: #8417aa40; filter: blur(100px);"></div>
  <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] rounded-full pointer-events-none" style="background: #07ffd230; filter: blur(80px);"></div>
  <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: radial-gradient(#e1a7f1 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative max-w-[1140px] mx-auto px-6">
    <div class="max-w-3xl">
      <div class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-medium uppercase tracking-widest mb-8" style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.75); font-family: 'Poppins', sans-serif;">
        {t.hero.badge}
      </div>

      <!-- Headline always in English regardless of locale -->
      <h1 style="font-family: 'Poppins', sans-serif; font-size: clamp(2.4rem, 6vw, 4.2rem); font-weight: 700; line-height: 1.05; color: white; letter-spacing: -0.02em;" class="mb-6">
        Global minds<br />
        <span style="color: #07ffd2;">connect.</span>
      </h1>

      <p class="leading-relaxed mb-10 max-w-2xl" style="font-size: clamp(0.95rem, 1.8vw, 1.05rem); color: rgba(255,255,255,0.65); font-family: 'Poppins', sans-serif; font-weight: 300;">
        {t.hero.subheadline}
      </p>

      <div class="flex flex-wrap gap-4">
        <a href={ctaHref} target="_blank" rel="noopener noreferrer" class="btn-primary">
          {t.hero.cta}
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href={secondaryHref} class="btn-secondary" style="border-color: #07ffd2; color: #07ffd2;">
          {t.hero.ctaSecondary}
        </a>
      </div>
    </div>
  </div>
</section>
