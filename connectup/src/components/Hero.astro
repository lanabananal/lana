---
import { getTranslations } from '../i18n/translations';
interface Props { locale: string; }
const { locale } = Astro.props;
const t = getTranslations(locale);

const isPtBr = locale === 'pt-br';
const ctaHref = 'https://wa.me/5511913062315';
const secondaryHref = isPtBr ? '#como-funciona' : `/${locale}#services`;

const statLabels = {
  taxRate: isPtBr ? 'Alíquota Máxima' : 'Max Tax Rate',
  days:    isPtBr ? 'Dias para Residência' : 'Days to Residency',
  foreign: isPtBr ? 'Imposto sobre Renda Exterior' : 'Tax on Foreign Income',
};
---

<section class="relative overflow-hidden pt-[120px] pb-20" style="background: linear-gradient(165deg, #1A1A1AF0 0%, #1a0a2eE8 40%, #8417aaCC 100%);">
  <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] rounded-full pointer-events-none" style="background: #8417aa40; filter: blur(100px);"></div>
  <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] rounded-full pointer-events-none" style="background: #07ffd230; filter: blur(80px);"></div>
  <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: radial-gradient(#e1a7f1 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative max-w-[1140px] mx-auto px-6">
    <div class="max-w-3xl">
      <div class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-medium uppercase tracking-widest mb-8" style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.75); font-family: 'DM Sans', sans-serif;">
        {t.hero.badge}
      </div>

      <h1 style="font-family: 'Fraunces', serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.1; color: white;" class="mb-8">
        {t.hero.headline}
        {isPtBr && <><br /><span style="color: #07ffd2;">{t.hero.headline2}</span></>}
        {!isPtBr && <><br /><span style="color: #e1a7f1;">{t.hero.headline2}</span></>}
      </h1>

      <p class="leading-relaxed mb-10 max-w-2xl" style="font-size: clamp(1rem, 2vw, 1.15rem); color: rgba(255,255,255,0.70); font-family: 'DM Sans', sans-serif; font-weight: 300;">
        {t.hero.subheadline}
      </p>

      <div class="flex flex-wrap gap-4">
        <a href={ctaHref} target="_blank" rel="noopener noreferrer" class="btn-primary">
          {t.hero.cta}
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href={secondaryHref} class="btn-secondary" style="border-color: #07ffd2; color: #07ffd2;">
          {t.hero.ctaSecondary}
        </a>
      </div>

      <div class="flex flex-wrap gap-8 mt-14 pt-10" style="border-top: 1px solid rgba(255,255,255,0.10);">
        <div>
          <div style="font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 700; color: white;">10%</div>
          <div style="font-size: 0.8rem; color: rgba(255,255,255,0.56); font-family: 'DM Sans';">{statLabels.taxRate}</div>
        </div>
        <div>
          <div style="font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 700; color: white;">60</div>
          <div style="font-size: 0.8rem; color: rgba(255,255,255,0.56); font-family: 'DM Sans';">{statLabels.days}</div>
        </div>
        <div>
          <div style="font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 700; color: white;">$0</div>
          <div style="font-size: 0.8rem; color: rgba(255,255,255,0.56); font-family: 'DM Sans';">{statLabels.foreign}</div>
        </div>
      </div>
    </div>
  </div>
</section>
