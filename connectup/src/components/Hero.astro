---
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section class="relative overflow-hidden pt-[120px] pb-20" style="background: linear-gradient(165deg, #1A1A1AF0 0%, #1a0a2eE8 40%, #5030E5D0 100%);">

  <!-- Glow orbs -->
  <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] rounded-full pointer-events-none" style="background: #5030E540; filter: blur(100px);"></div>
  <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] rounded-full pointer-events-none" style="background: #00B3E330; filter: blur(80px);"></div>

  <!-- Dot pattern -->
  <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: radial-gradient(#BB89FF 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative max-w-[1140px] mx-auto px-6">
    <div class="max-w-3xl">

      <!-- Tag -->
      <div class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-widest mb-8" style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.75);">
        {t.hero.badge}
      </div>

      <!-- Headline -->
      <h1 class="font-black text-white leading-[1.1] tracking-tight mb-8" style="font-size: clamp(36px, 6vw, 64px); letter-spacing: -0.03em;">
        {t.hero.headline}
        <br />
        <span style="color: #BB89FF;">{t.hero.headline2}</span>
      </h1>

      <!-- Subheadline -->
      <p class="leading-relaxed mb-10 max-w-2xl" style="font-size: clamp(16px, 2vw, 19px); color: rgba(255,255,255,0.70);">
        {t.hero.subheadline}
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a
          href="https://web.whatsapp.com/send?phone=5511913062315"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-semibold rounded-[10px] transition-all duration-200 hover:-translate-y-px"
          style="background: #5030E5; color: white; padding: 14px 28px; font-size: 15px;"
        >
          {t.hero.cta}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={`/${locale}#services`}
          class="inline-flex items-center gap-2 font-semibold rounded-[10px] transition-all duration-200 hover:-translate-y-px"
          style="border: 2px solid #00B3E3; color: #00B3E3; padding: 14px 28px; font-size: 15px;"
        >
          {t.hero.ctaSecondary}
        </a>
      </div>

      <!-- Stats -->
      <div class="flex flex-wrap gap-8 mt-14 pt-10" style="border-top: 1px solid rgba(255,255,255,0.10);">
        <div>
          <div class="text-3xl font-black text-white">10%</div>
          <div class="text-sm" style="color: rgba(255,255,255,0.56);">Max Tax Rate</div>
        </div>
        <div>
          <div class="text-3xl font-black text-white">60</div>
          <div class="text-sm" style="color: rgba(255,255,255,0.56);">Days to Residency</div>
        </div>
        <div>
          <div class="text-3xl font-black text-white">$0</div>
          <div class="text-sm" style="color: rgba(255,255,255,0.56);">Tax on Foreign Income</div>
        </div>
      </div>

    </div>
  </div>
</section>
