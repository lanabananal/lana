---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, isValidLocale, getTranslations } from '../../i18n/translations';

export function getStaticPaths() {
  return locales.map(locale => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect('/en/contact', 302);
const t = getTranslations(locale);
const ct = (t as any).contact ?? {
  tag: 'Contact', title: 'Get in touch', subtitle: 'We respond within 24 hours.',
  namePlaceholder: 'Your name', phonePlaceholder: 'Your phone',
  emailPlaceholder: 'your@email.com', messagePlaceholder: 'How can we help?',
  submit: 'Send message',
};
---

<BaseLayout locale={locale} title={ct.title}>
  <div style="padding-top:80px;min-height:100vh;background:#f7f4fa;">
    <div style="max-width:960px;margin:0 auto;padding:4rem 1.5rem;">

      <div style="text-align:center;margin-bottom:3rem;">
        <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#795389;">{ct.tag}</span>
        <h1 style="font-family:'Poppins',sans-serif;font-size:clamp(1.6rem,3.5vw,2.2rem);font-weight:600;margin-top:0.5rem;">{ct.title}</h1>
        <p style="font-family:'Poppins',sans-serif;font-size:0.95rem;font-weight:300;color:#795389;margin-top:0.5rem;">{ct.subtitle}</p>
      </div>

      <!-- Card with photo + contact options + form -->
      <div style="background:white;border-radius:16px;border:1px solid #dfdede;overflow:hidden;">
        <!-- Top: bio card -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:1px solid #dfdede;" class="contact-top">
          <div style="padding:2rem;background:#f7f4fa;display:flex;flex-direction:column;gap:1rem;">
            <div style="display:flex;align-items:center;gap:1rem;">
              <img src="/lana-profissa.jpg" alt="Lana" style="width:80px;height:80px;border-radius:50%;object-fit:cover;object-position:top;" />
              <div>
                <p style="font-family:'Poppins',sans-serif;font-weight:600;font-size:0.95rem;">Lana · ConnectUp</p>
                <p style="font-family:'Poppins',sans-serif;font-weight:300;font-size:0.8rem;color:#795389;">Fundadora & Consultora</p>
              </div>
            </div>
            <p style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:300;color:#555;line-height:1.7;">Vim ao Paraguai para entender o sistema por dentro e me tornei o elo que faltava.</p>
            <a href={`/${locale}/about`} style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;color:#8417aa;">Conhecer mais sobre a ConnectUp →</a>
          </div>
          <div style="padding:2rem;display:flex;flex-direction:column;gap:1rem;justify-content:center;">
            <a href="https://wa.me/5511913062315" target="_blank" rel="noopener noreferrer" style="display:inline-flex;align-items:center;gap:8px;background:#f7f4fa;border:1px solid #dfdede;border-radius:8px;padding:12px 16px;font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;color:#1a1a1a;text-decoration:none;transition:border-color 0.2s;" onmouseover="this.style.borderColor='#8417aa'" onmouseout="this.style.borderColor='#dfdede'">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#8417aa" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
              WhatsApp +55 11 91306-2315
            </a>
            <a href="mailto:lana@theconnectup.com" style="display:inline-flex;align-items:center;gap:8px;background:#f7f4fa;border:1px solid #dfdede;border-radius:8px;padding:12px 16px;font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;color:#1a1a1a;text-decoration:none;transition:border-color 0.2s;" onmouseover="this.style.borderColor='#8417aa'" onmouseout="this.style.borderColor='#dfdede'">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#8417aa" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              lana@theconnectup.com
            </a>
            <a href="https://calendly.com/lana-theconnectup/aula-demo" target="_blank" rel="noopener noreferrer" style="display:inline-flex;align-items:center;gap:8px;background:#f7f4fa;border:1px solid #dfdede;border-radius:8px;padding:12px 16px;font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:500;color:#1a1a1a;text-decoration:none;transition:border-color 0.2s;" onmouseover="this.style.borderColor='#8417aa'" onmouseout="this.style.borderColor='#dfdede'">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#8417aa" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              Agendar reunião (Calendly)
            </a>
          </div>
        </div>

        <!-- Form -->
        <form name="contato" method="POST" data-netlify="true" netlify-honeypot="bot-field" action={`/${locale}/obrigado`} style="padding:2rem;">
          <input type="hidden" name="form-name" value="contato" />
          <p style="display:none;"><input name="bot-field" /></p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;" class="form-row">
            <div>
              <input type="text" name="name" required placeholder={ct.namePlaceholder} class="form-input" />
            </div>
            <div>
              <input type="tel" name="phone" placeholder={ct.phonePlaceholder} class="form-input" />
            </div>
          </div>
          <div style="margin-bottom:1rem;">
            <input type="email" name="email" required placeholder={ct.emailPlaceholder} class="form-input" />
          </div>
          <div style="margin-bottom:1.5rem;">
            <textarea name="message" rows="4" placeholder={ct.messagePlaceholder} class="form-input" style="resize:vertical;"></textarea>
          </div>
          <button type="submit" style="background:#8417aa;color:white;font-family:'Poppins',sans-serif;font-weight:500;padding:14px 28px;border-radius:8px;border:none;cursor:pointer;width:100%;font-size:0.95rem;transition:background 0.2s;" onmouseover="this.style.background='#470050'" onmouseout="this.style.background='#8417aa'">
            {ct.submit}
          </button>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
.form-input {
  width: 100%;
  padding: 12px 14px;
  border: 1px solid #dfdede;
  border-radius: 8px;
  font-family: 'Poppins', sans-serif;
  font-size: 0.9rem;
  font-weight: 300;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  box-sizing: border-box;
}
.form-input:focus {
  border-color: #8417aa;
  box-shadow: 0 0 0 3px rgba(132,23,170,0.1);
}
@media (max-width: 640px) {
  .contact-top { grid-template-columns: 1fr !important; }
  .form-row { grid-template-columns: 1fr !important; }
}
</style>
