const c = content[locale] ?? content['en'];
---

<BaseLayout locale={locale} title={c.seoTitle} description={c.seoDesc}>
  <div style="padding-top:80px;">

    <!-- HERO -->
    <section class="relative overflow-hidden pt-20 pb-20" style="background:linear-gradient(165deg,#1A1A1AF0 0%,#1a0a2eE8 40%,#07ffd218 100%);">
      <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] rounded-full pointer-events-none" style="background:#07ffd215;filter:blur(100px);"></div>
      <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] rounded-full pointer-events-none" style="background:#8417aa30;filter:blur(80px);"></div>
      <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image:radial-gradient(#07ffd2 1px,transparent 1px);background-size:32px 32px;"></div>

      <div class="relative max-w-[1140px] mx-auto px-6">
        <div class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-medium uppercase tracking-widest mb-8" style="background:rgba(7,255,210,0.08);border:1px solid rgba(7,255,210,0.2);color:rgba(7,255,210,0.85);font-family:'Poppins',sans-serif;">
          {c.badge}
        </div>
        <h1 style="font-family:'Poppins',sans-serif;font-size:clamp(2rem,5vw,3.2rem);font-weight:600;line-height:1.1;color:white;" class="mb-4">
          {c.h1}<br />
          <span style="color:#07ffd2;">{c.h1accent}</span>
        </h1>
        <p style="font-family:'Poppins',sans-serif;font-size:clamp(1rem,2vw,1.15rem);color:rgba(255,255,255,0.70);font-weight:300;max-width:640px;line-height:1.7;" class="mb-4">
          {c.subtitle}
        </p>
        <p style="font-family:'Poppins',sans-serif;font-size:0.95rem;color:rgba(255,255,255,0.60);font-weight:300;max-width:680px;line-height:1.8;">
          {c.desc}
        </p>
      </div>
    </section>

    <!-- WHY PARAGUAY — B&W + purple -->
    <section class="relative py-16 px-6">
      <div class="absolute inset-0" style="background-image:url('/meeting.jpg');background-size:cover;background-position:center;filter:grayscale(1) brightness(0.35);"></div>
      <div class="absolute inset-0" style="background:rgba(0,80,60,0.28);"></div>
      <div class="relative max-w-[1140px] mx-auto" style="z-index:2;">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#07ffd2;">{c.whyTag}</span>
          <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.6rem,3.5vw,2.2rem);font-weight:600;color:white;margin-top:0.5rem;">{c.whyTitle}</h2>
        </div>
        <div class="why-grid">
          {c.whyItems.map((item: any) => (
            <div class="glass-card">
              <div style="font-family:'Poppins',sans-serif;font-size:1.4rem;font-weight:700;color:#07ffd2;margin-bottom:0.5rem;line-height:1;">{item.n}</div>
              <h3 style="font-family:'Poppins',sans-serif;font-size:0.92rem;font-weight:600;color:white;margin-bottom:0.4rem;">{item.title}</h3>
              <p style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:300;color:rgba(255,255,255,0.75);line-height:1.6;">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ASSISTA -->
    <section style="background:linear-gradient(135deg,#07ffd2 0%,#5a1f8c 100%);padding:4rem 1.5rem;">
      <div style="max-width:800px;margin:0 auto;text-align:center;">
        <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(255,255,255,0.75);margin-bottom:0.6rem;">{c.assistaTag}</span>
        <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.4rem,3vw,2rem);font-weight:700;color:#fff;margin-bottom:0.75rem;">{c.assistaTitle}</h2>
        <p style="font-family:'Poppins',sans-serif;font-size:0.95rem;color:rgba(255,255,255,0.8);font-weight:300;max-width:560px;margin:0 auto 2rem;line-height:1.7;">{c.assistaSub}</p>
        <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,0.3);background:#0a0010;">
          <iframe
            src={`https://www.youtube.com/embed/${c.videoId}`}
            title={c.assistaTitle}
            style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <!-- CALCULATOR -->
    <section style="background:#0a0010;padding:4rem 1.5rem;">
      <div style="max-width:600px;margin:0 auto;text-align:center;">
        <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#07ffd2;margin-bottom:0.75rem;">{c.calcTag}</span>
        <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.4rem,3vw,1.9rem);font-weight:600;color:white;margin-bottom:0.75rem;">{c.calcTitle}</h2>
        <p style="font-family:'Poppins',sans-serif;font-size:0.92rem;font-weight:300;color:rgba(255,255,255,0.60);line-height:1.7;margin-bottom:2rem;">{c.calcDesc}</p>
        <div style="border-radius:20px;overflow:hidden;border:1px solid rgba(7,255,210,0.2);box-shadow:0 0 60px rgba(7,255,210,0.08);">
          <iframe
            id="calc-iframe"
            src="/calculadora-fiscal.html"
            title="Tax Savings Calculator — ConnectUP"
            width="100%"
            height="680"
            style="display:block;border:none;background:transparent;"
          ></iframe>
        </div>
        <script is:inline>
          window.addEventListener('message', function(e) {
            if (e.data && e.data.type === 'calc-height') {
              var f = document.getElementById('calc-iframe');
              if (f) f.height = Math.max(680, e.data.height + 32);
            }
          });
        </script>
      </div>
    </section>

    <!-- PRICING -->
    <section style="background:#f0fdf8;padding:4rem 1.5rem;border-top:1px solid rgba(7,255,210,0.2);">
      <div style="max-width:680px;margin:0 auto;text-align:center;">
        <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#006655;margin-bottom:0.75rem;">{c.pricingTag}</span>
        <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.4rem,3vw,1.9rem);font-weight:600;color:#1a1a1a;margin-bottom:1.5rem;">{c.pricingTitle}</h2>
        <div style="background:white;border:1.5px solid rgba(7,255,210,0.35);border-radius:16px;padding:2rem 2.5rem;box-shadow:0 4px 24px rgba(7,255,210,0.07);">
          <div style="font-family:'Poppins',sans-serif;font-size:2.2rem;font-weight:700;color:#006655;margin-bottom:0.25rem;">{c.pricingPrice}</div>
          <p style="font-family:'Poppins',sans-serif;font-size:0.78rem;color:#777;margin-bottom:1.5rem;font-weight:300;">{c.pricingNote}</p>
          <ul style="list-style:none;margin:0;padding:0;text-align:left;">
            {c.pricingIncludes.map((item: string) => (
              <li style="display:flex;align-items:flex-start;gap:0.6rem;padding:0.5rem 0;font-family:'Poppins',sans-serif;font-size:0.88rem;color:#333;border-bottom:1px solid #f0f0f0;">
                <span style="color:#07c9a8;font-weight:700;flex-shrink:0;margin-top:1px;">✓</span>
                {item}
              </li>
            ))}
          </ul>
          <div style="margin-top:1.75rem;">
            <a href="https://calendly.com/lana-theconnectup/connectup" target="_blank" rel="noopener noreferrer"
