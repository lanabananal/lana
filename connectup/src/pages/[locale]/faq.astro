---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, isValidLocale } from '../../i18n/translations';

export function getStaticPaths() {
  return locales.map(locale => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect('/en/', 302);

const content: Record<string, any> = {
  'en': {
    seoTitle: 'FAQ — Paraguay Tax Residency | ConnectUP',
    seoDesc: 'Answers to the most common questions about Paraguay tax residency, cedula, RUC, company formation, and fiscal exit from Brazil.',
    badge: 'FAQ',
    h1: 'Frequently Asked',
    h1accent: 'Questions',
    subtitle: 'Everything you need to know about Paraguay tax residency.',
    items: [
      { q: 'How long does the Paraguay tax residency process take?', a: 'The full process typically takes 60 days. It requires two trips to Asunción of approximately 5 business days each. ConnectUP coordinates everything from document preparation to accompanying you on both trips.' },
      { q: 'Do I need to live in Paraguay to maintain tax residency?', a: 'No. Temporary residency requires just one visit per year. Permanent residency requires one visit every 36 months. There is no minimum days-in-country requirement.' },
      { q: 'Will Paraguay tax my foreign income?', a: 'No. Paraguay operates on a territorial tax system. Only income generated within Paraguay is taxed at a flat 10% rate. All foreign-sourced income — remote work, freelance, dividends, capital gains from foreign assets — is 100% exempt.' },
      { q: 'How much does Paraguay tax residency cost with ConnectUP?', a: 'Our packages start from $2,000 USD, which includes government and consular fees, document preparation, accompaniment on both trips, company and RUC setup, and 30 days of post-residency support. Contact us for a personalized quote.' },
      { q: 'What is the RUC and do I need it?', a: 'The RUC (Registro Único del Contribuyente) is Paraguay\'s tax identification number. It is required to open a bank account, issue invoices in Paraguay, and obtain your SET fiscal residency certificate. ConnectUP includes RUC registration as part of the process.' },
      { q: 'What is the SET certificate and why does it matter?', a: 'The SET (Subsecretaría de Estado de Tributación) certificate is the official fiscal residency certificate issued by Paraguay\'s tax authority. It is required by banks, brokers, and cryptocurrency exchanges to prove your tax domicile. It requires an active RUC and up-to-date tax filings.' },
      { q: 'Can I keep my assets and investments in my home country?', a: 'Yes. Stocks, real estate, bank accounts, and investments in your home country remain yours. You simply operate as a non-resident for tax purposes in your origin country, following the applicable fiscal exit rules.' },
      { q: 'Do I need to close my company or MEI in Brazil?', a: 'Solo entrepreneurs (MEI) and individual firms typically need to be closed or converted. LTD, S.A., and partnerships can generally be kept. ConnectUP and its legal partners will advise you based on your specific structure.' },
      { q: 'Is Paraguay tax residency legal?', a: 'Yes. Paraguay tax residency is a treaty-compliant, internationally recognized legal mechanism. It is based on Paraguay\'s territorial tax system, which has been in place for decades. ConnectUP works with licensed Paraguayan attorneys throughout the process.' },
      { q: 'Can I open a bank account in Paraguay?', a: 'Yes. Once you have your cedula, you can open accounts at Paraguayan banks in both USD and Guaraní. ConnectUP assists with bank account opening as part of the post-residency support.' },
    ],
    ctaTitle: 'Still have questions?',
    ctaBtn: 'Book a free consultation →',
    ctaNote: 'Free · No commitment',
  },
  'pt-br': {
    seoTitle: 'FAQ — Residência Fiscal no Paraguai | ConnectUP',
    seoDesc: 'Respostas às perguntas mais frequentes sobre residência fiscal no Paraguai, cédula, RUC, abertura de empresa e saída fiscal do Brasil.',
    badge: 'FAQ',
    h1: 'Perguntas',
    h1accent: 'Frequentes',
    subtitle: 'Tudo que você precisa saber sobre a residência fiscal no Paraguai.',
    items: [
      { q: 'Quanto tempo leva o processo de residência fiscal no Paraguai?', a: 'O processo completo leva em média 60 dias. São necessárias duas viagens a Assunção de aproximadamente 5 dias úteis cada. A ConnectUP coordena tudo — da preparação dos documentos até o acompanhamento nas duas viagens.' },
      { q: 'Preciso morar no Paraguai para manter a residência fiscal?', a: 'Não. A residência temporária exige apenas uma visita por ano. A permanente exige uma visita a cada 36 meses. Não existe exigência de dias mínimos no país.' },
      { q: 'O Paraguai vai tributar minha renda do exterior?', a: 'Não. O Paraguai adota o sistema de tributação territorial. Apenas a renda gerada dentro do Paraguai é tributada à alíquota de 10%. Toda renda do exterior — trabalho remoto, freelance, dividendos, ganhos de capital — é 100% isenta.' },
      { q: 'Quanto custa a residência fiscal no Paraguai com a ConnectUP?', a: 'Nossos pacotes começam a partir de R$ 12.000, incluindo taxas governamentais e consulares, preparação de documentos, acompanhamento nas duas viagens, abertura de empresa e RUC, e 30 dias de suporte pós-residência. Solicite uma proposta personalizada.' },
      { q: 'O que é o RUC e por que eu preciso dele?', a: 'O RUC (Registro Único del Contribuyente) é o número de identificação fiscal do Paraguai. É necessário para abrir conta bancária, emitir notas fiscais e obter o certificado SET de residência fiscal. A ConnectUP inclui o registro do RUC no processo.' },
      { q: 'O que é o certificado SET e por que ele é importante?', a: 'O certificado SET é o documento oficial de residência fiscal emitido pelo fisco paraguaio. É exigido por bancos, corretoras e exchanges de criptomoedas para comprovar o domicílio fiscal. Requer RUC ativo e declarações em dia.' },
      { q: 'Posso manter meus bens e investimentos no Brasil?', a: 'Sim. Ações, imóveis, contas bancárias e investimentos no Brasil continuam sendo seus. Você passa a operar como não-residente fiscal no Brasil, seguindo as regras de saída fiscal aplicáveis.' },
      { q: 'Preciso fechar meu MEI ou empresa no Brasil?', a: 'MEI e firmas individuais geralmente precisam ser encerradas ou convertidas. Ltda., S.A. e sociedades podem ser mantidas na maioria dos casos. A ConnectUP e seus parceiros jurídicos orientam conforme sua estrutura específica.' },
      { q: 'A residência fiscal no Paraguai é legal?', a: 'Sim. A residência fiscal no Paraguai é um mecanismo legal, reconhecido internacionalmente e compatível com tratados. Baseia-se no sistema tributário territorial do Paraguai, vigente há décadas. A ConnectUP trabalha com advogados paraguaios licenciados em todo o processo.' },
      { q: 'Posso abrir conta bancária no Paraguai?', a: 'Sim. Com a cédula em mãos, é possível abrir contas em bancos paraguaios em dólares e guaranis. A ConnectUP auxilia na abertura de conta como parte do suporte pós-residência.' },
    ],
    ctaTitle: 'Ainda tem dúvidas?',
    ctaBtn: 'Agendar consulta gratuita →',
    ctaNote: 'Gratuita · Sem compromisso',
  },
  'es': {
    seoTitle: 'FAQ — Residencia Fiscal en Paraguay | ConnectUP',
    seoDesc: 'Respuestas a las preguntas más frecuentes sobre residencia fiscal en Paraguay, cédula, RUC, apertura de empresa y salida fiscal.',
    badge: 'FAQ',
    h1: 'Preguntas',
    h1accent: 'Frecuentes',
    subtitle: 'Todo lo que necesitas saber sobre la residencia fiscal en Paraguay.',
    items: [
      { q: '¿Cuánto tiempo dura el proceso de residencia fiscal en Paraguay?', a: 'El proceso completo tarda aproximadamente 60 días. Requiere dos viajes a Asunción de unos 5 días hábiles cada uno. ConnectUP coordina todo, desde la preparación de documentos hasta el acompañamiento en ambos viajes.' },
      { q: '¿Necesito vivir en Paraguay para mantener la residencia fiscal?', a: 'No. La residencia temporal exige solo una visita al año. La permanente exige una visita cada 36 meses. No hay requisito de días mínimos en el país.' },
      { q: '¿Paraguay gravará mis ingresos del exterior?', a: 'No. Paraguay opera con un sistema de tributación territorial. Solo se gravan los ingresos generados dentro de Paraguay a una tasa plana del 10%. Todos los ingresos extranjeros — trabajo remoto, freelance, dividendos, ganancias de capital — están 100% exentos.' },
      { q: '¿Cuánto cuesta la residencia fiscal en Paraguay con ConnectUP?', a: 'Nuestros paquetes comienzan desde $2,000 USD, incluyendo honorarios gubernamentales y consulares, preparación de documentos, acompañamiento en ambos viajes, apertura de empresa y RUC, y 30 días de soporte post-residencia. Solicita una propuesta personalizada.' },
      { q: '¿Qué es el RUC y por qué lo necesito?', a: 'El RUC (Registro Único del Contribuyente) es el número de identificación fiscal de Paraguay. Es necesario para abrir una cuenta bancaria, emitir facturas y obtener el certificado SET de residencia fiscal. ConnectUP incluye el registro del RUC en el proceso.' },
      { q: '¿Qué es el certificado SET y por qué es importante?', a: 'El certificado SET es el documento oficial de residencia fiscal emitido por la autoridad tributaria de Paraguay. Es requerido por bancos, corredores de bolsa e intercambios de criptomonedas para acreditar el domicilio fiscal. Requiere RUC activo y declaraciones al día.' },
      { q: '¿Puedo mantener mis activos e inversiones en mi país de origen?', a: 'Sí. Acciones, bienes raíces, cuentas bancarias e inversiones en tu país de origen se mantienen intactos. Simplemente operas como no residente fiscal en tu país de origen, siguiendo las reglas de salida fiscal aplicables.' },
      { q: '¿Es legal la residencia fiscal en Paraguay?', a: 'Sí. La residencia fiscal en Paraguay es un mecanismo legal, reconocido internacionalmente y compatible con tratados. Se basa en el sistema tributario territorial de Paraguay, vigente desde hace décadas. ConnectUP trabaja con abogados paraguayos habilitados en todo el proceso.' },
      { q: '¿Puedo abrir una cuenta bancaria en Paraguay?', a: 'Sí. Con la cédula en mano, puedes abrir cuentas en bancos paraguayos en dólares y guaraníes. ConnectUP asiste en la apertura de cuenta como parte del soporte post-residencia.' },
    ],
    ctaTitle: '¿Todavía tienes preguntas?',
    ctaBtn: 'Agendar consulta gratuita →',
    ctaNote: 'Gratuita · Sin compromiso',
  },
  'pl': {
    seoTitle: 'FAQ — Rezydencja Podatkowa w Paragwaju | ConnectUP',
    seoDesc: 'Odpowiedzi na najczęstsze pytania dotyczące rezydencji podatkowej w Paragwaju, cédula, RUC, zakładania firmy i wyjścia podatkowego.',
    badge: 'FAQ',
    h1: 'Najczęściej Zadawane',
    h1accent: 'Pytania',
    subtitle: 'Wszystko, co musisz wiedzieć o rezydencji podatkowej w Paragwaju.',
    items: [
      { q: 'Jak długo trwa proces rezydencji podatkowej w Paragwaju?', a: 'Pełny proces trwa około 60 dni. Wymaga dwóch podróży do Asunción po około 5 dni roboczych każda. ConnectUP koordynuje wszystko — od przygotowania dokumentów po towarzyszenie podczas obu wizyt.' },
      { q: 'Czy muszę mieszkać w Paragwaju, aby utrzymać rezydencję podatkową?', a: 'Nie. Rezydencja tymczasowa wymaga tylko jednej wizyty rocznie. Stała rezydencja wymaga jednej wizyty co 36 miesięcy. Nie ma wymogu minimalnej liczby dni w kraju.' },
      { q: 'Czy Paragwaj opodatkuje moje dochody zagraniczne?', a: 'Nie. Paragwaj stosuje terytorialny system podatkowy. Opodatkowane są wyłącznie dochody uzyskane w Paragwaju według stawki 10%. Wszelkie dochody zagraniczne — praca zdalna, freelance, dywidendy, zyski kapitałowe — są w 100% zwolnione z podatku.' },
      { q: 'Ile kosztuje rezydencja podatkowa w Paragwaju z ConnectUP?', a: 'Nasze pakiety zaczynają się od 2 000 USD, w tym opłaty rządowe i konsularne, przygotowanie dokumentów, towarzyszenie podczas obu podróży, założenie firmy i rejestracja RUC oraz 30 dni wsparcia po uzyskaniu rezydencji. Skontaktuj się z nami, aby otrzymać spersonalizowaną ofertę.' },
      { q: 'Czym jest RUC i dlaczego go potrzebuję?', a: 'RUC (Registro Único del Contribuyente) to paragwajski numer identyfikacji podatkowej. Jest wymagany do otwarcia rachunku bankowego, wystawiania faktur w Paragwaju i uzyskania certyfikatu SET rezydencji podatkowej. ConnectUP obejmuje rejestrację RUC w procesie.' },
      { q: 'Czym jest certyfikat SET i dlaczego jest ważny?', a: 'Certyfikat SET to oficjalny dokument rezydencji podatkowej wydawany przez paragwajski urząd skarbowy. Jest wymagany przez banki, brokerów i giełdy kryptowalut jako dowód miejsca zamieszkania do celów podatkowych. Wymaga aktywnego RUC i aktualnych deklaracji podatkowych.' },
      { q: 'Czy mogę zatrzymać swoje aktywa i inwestycje w kraju ojczystym?', a: 'Tak. Akcje, nieruchomości, rachunki bankowe i inwestycje w Twoim kraju pozostają Twoje. Po prostu funkcjonujesz jako nierezydent podatkowy w swoim kraju ojczystym, zgodnie z obowiązującymi przepisami dotyczącymi wyjścia podatkowego.' },
      { q: 'Czy rezydencja podatkowa w Paragwaju jest legalna?', a: 'Tak. Rezydencja podatkowa w Paragwaju jest legalnym, uznawanym przez prawo międzynarodowe i zgodnym z traktatami mechanizmem. Opiera się na terytorialnym systemie podatkowym Paragwaju, który obowiązuje od dziesięcioleci. ConnectUP współpracuje z licencjonowanymi paragwajskimi prawnikami przez cały proces.' },
      { q: 'Czy mogę otworzyć konto bankowe w Paragwaju?', a: 'Tak. Po uzyskaniu cédula możesz otworzyć rachunki w paragwajskich bankach w dolarach i guaraníes. ConnectUP pomaga w otwarciu konta bankowego w ramach wsparcia po uzyskaniu rezydencji.' },
    ],
    ctaTitle: 'Masz jeszcze pytania?',
    ctaBtn: 'Umów bezpłatną konsultację →',
    ctaNote: 'Bezpłatna · Bez zobowiązań',
  },
};

const c = content[locale] ?? content['en'];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: c.items.map((item: any) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout locale={locale} title={c.seoTitle} description={c.seoDesc}>
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} slot="head" />

  <div style="padding-top:80px;">

    <!-- HERO -->
    <section class="py-20 px-6" style="background:linear-gradient(165deg,#1A1A1AF0 0%,#1a0a2eE8 100%);">
      <div class="max-w-[860px] mx-auto text-center">
        <div class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-medium uppercase tracking-widest mb-6" style="background:rgba(7,255,210,0.08);border:1px solid rgba(7,255,210,0.2);color:rgba(7,255,210,0.85);font-family:'Poppins',sans-serif;">
          {c.badge}
        </div>
        <h1 style="font-family:'Poppins',sans-serif;font-size:clamp(2rem,5vw,3rem);font-weight:600;color:white;line-height:1.15;margin-bottom:1rem;">
          {c.h1}<br/><span style="color:#07ffd2;">{c.h1accent}</span>
        </h1>
        <p style="font-family:'Poppins',sans-serif;font-size:1.05rem;color:rgba(255,255,255,0.65);font-weight:300;max-width:560px;margin:0 auto;">
          {c.subtitle}
        </p>
      </div>
    </section>

    <!-- FAQ ACCORDION -->
    <section class="py-16 px-6" style="background:#fafafa;">
      <div class="max-w-[860px] mx-auto">
        <div class="space-y-3">
          {c.items.map((item: any, i: number) => (
            <details class="faq-item" style="background:white;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;">
              <summary style="font-family:'Poppins',sans-serif;font-size:0.97rem;font-weight:600;color:#1a1a1a;padding:1.25rem 1.5rem;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:1rem;">
                {item.q}
                <span class="faq-icon" style="flex-shrink:0;width:20px;height:20px;border-radius:50%;background:#07ffd2;display:flex;align-items:center;justify-content:center;font-size:0.85rem;font-weight:700;color:#003830;">+</span>
              </summary>
              <div style="padding:0 1.5rem 1.25rem;font-family:'Poppins',sans-serif;font-size:0.9rem;color:#555;line-height:1.75;border-top:1px solid #f0f0f0;margin-top:-1px;">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 px-6 text-center" style="background:linear-gradient(135deg,#003830,#006655);">
      <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.4rem,3vw,1.9rem);font-weight:600;color:white;margin-bottom:1.5rem;">{c.ctaTitle}</h2>
      <a href="https://calendly.com/lana-theconnectup/connectup" target="_blank" rel="noopener noreferrer"
        style="display:inline-flex;align-items:center;gap:8px;background:#07ffd2;color:#003830;font-family:'Poppins',sans-serif;font-weight:600;padding:14px 28px;border-radius:8px;">
        {c.ctaBtn}
      </a>
      <p style="font-family:'Poppins',sans-serif;font-size:11px;color:rgba(255,255,255,0.45);margin-top:1rem;">{c.ctaNote}</p>
    </section>

  </div>
</BaseLayout>

<style>
details[open] .faq-icon { content: '−'; background: #8417aa; color: white; }
details[open] .faq-icon::after { content: '−'; }
.faq-icon::after { content: '+'; }
details summary::-webkit-details-marker { display: none; }
</style>
