---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import { locales, isValidLocale } from '../../i18n/translations';

export function getStaticPaths() {
  return locales.map(locale => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect('/en/', 302);

const content: Record<string, any> = {
  'pt-br': {
    seoTitle: 'Planejamento Financeiro Internacional | Renda em Dólar e Euro | ConnectUP',
    seoDesc: 'Você recebe em dólar, euro ou libra e não sabe como otimizar sua carga tributária? Planejamento financeiro para profissionais com renda em múltiplas moedas.',
    badge: 'ConnectUP',
    h1: 'Planejamento Financeiro',
    h1accent: 'Internacional',
    subtitle: 'Para profissionais que recebem em múltiplas moedas e precisam pagar menos imposto — de forma legal.',
    desc: 'Receber em dólar, euro ou libra é uma conquista. Mas sem planejamento, você paga impostos como se fosse um profissional local — e perde uma parte significativa disso que veio de fora. Existe uma forma melhor.',
    challengeTag: 'O problema',
    challengeTitle: 'Por que renda em múltiplas moedas exige planejamento específico',
    challenges: [
      {
        n: '01',
        title: 'Câmbio e tributação simultâneos',
        desc: 'Quando você converte dólares para reais, não é só câmbio — é um evento fiscal. Dependendo de como está estruturado, você pode estar pagando imposto duas vezes sobre o mesmo valor.',
      },
      {
        n: '02',
        title: 'Regras diferentes para cada fonte',
        desc: 'Rendimento de cliente americano, dividendo de empresa estrangeira, salário de empresa europeia — cada um tem tratamento fiscal diferente. Confundir isso custa caro.',
      },
      {
        n: '03',
        title: 'Falta de estrutura jurídica adequada',
        desc: 'Receber como pessoa física quando deveria receber como empresa (ou vice-versa) pode triplicar sua carga tributária sem que você perceba.',
      },
      {
        n: '04',
        title: 'Variação cambial não planejada',
        desc: 'O câmbio sobe — e com ele o imposto. Sem hedge financeiro ou estrutura adequada, você paga mais imposto exatamente quando mais precisa de liquidez.',
      },
    ],
    solutionTag: 'O que fazemos',
    solutionTitle: 'Como estruturamos seu planejamento',
    solutions: [
      {
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
        title: 'Diagnóstico da situação atual',
        desc: 'Mapeamos todas as suas fontes de renda em moeda estrangeira, estruturas jurídicas existentes e carga tributária real — não estimada.',
      },
      {
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>`,
        title: 'Estratégia de estruturação',
        desc: 'Definimos a melhor estrutura para receber — empresa paraguaia, holding internacional, conta não-residente — com base no seu perfil e volume.',
      },
      {
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/>`,
        title: 'Planejamento fiscal integrado',
        desc: 'Integramos o planejamento financeiro com o fiscal — incluindo residência no Paraguai quando aplicável — para uma visão completa e coerente.',
      },
    ],
    whoTag: 'Para quem',
    whoTitle: 'Esse serviço é para você se',
    who: [
      { n: '01', text: 'Recebe pagamentos em dólar, euro, libra ou outra moeda estrangeira' },
      { n: '02', text: 'Tem clientes ou empregadores em mais de um país' },
      { n: '03', text: 'Está considerando abertura de empresa fora do Brasil' },
      { n: '04', text: 'Quer entender o impacto fiscal de mudar de residência fiscal' },
      { n: '05', text: 'Investe em ativos no exterior (ações, ETFs, crypto, fundos)' },
    ],
    ctaTitle: 'Vamos mapear sua situação sem compromisso?',
    ctaBtn: 'Agendar diagnóstico gratuito →',
    ctaSecondary: 'Fale pelo WhatsApp',
    ctaNote: 'Consulta gratuita · 30 minutos · Sem compromisso',
  },
  'en': {
    seoTitle: 'International Financial Planning | Multi-Currency Income | ConnectUP',
    seoDesc: 'Receiving income in dollars, euros or pounds and not sure how to optimize your tax burden? Financial planning for professionals with multi-currency income.',
    badge: 'ConnectUP',
    h1: 'International Financial',
    h1accent: 'Planning',
    subtitle: 'For professionals receiving in multiple currencies who need to pay less tax — legally.',
    desc: 'Earning in dollars, euros or pounds is an achievement. But without planning, you pay taxes as if you were a local professional — losing a significant portion of that foreign income. There is a better way.',
    challengeTag: 'The problem',
    challengeTitle: 'Why multi-currency income requires specific planning',
    challenges: [
      { n: '01', title: 'Currency conversion and taxation', desc: 'When you convert dollars to your local currency, it is not just an exchange — it is a tax event. Depending on how it is structured, you may be paying tax twice on the same amount.' },
      { n: '02', title: 'Different rules for each source', desc: 'Revenue from a US client, dividends from a foreign company, salary from a European firm — each has different tax treatment. Mixing them up is costly.' },
      { n: '03', title: 'Wrong legal structure', desc: 'Receiving as an individual when you should receive as a company (or vice versa) can triple your tax burden without you realizing it.' },
      { n: '04', title: 'Unplanned currency fluctuation', desc: 'The exchange rate rises — and so does your tax. Without a hedge or proper structure, you pay more tax exactly when you need liquidity most.' },
    ],
    solutionTag: 'What we do',
    solutionTitle: 'How we structure your planning',
    solutions: [
      { icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"/>`, title: 'Current situation diagnosis', desc: 'We map all your foreign currency income sources, existing legal structures and real tax burden — not estimated.' },
      { icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>`, title: 'Structuring strategy', desc: 'We define the best structure for receiving income — Paraguayan company, international holding, non-resident account — based on your profile and volume.' },
      { icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/>`, title: 'Integrated tax planning', desc: 'We integrate financial planning with tax strategy — including Paraguay residency where applicable — for a complete and coherent overview.' },
    ],
    whoTag: 'Who it is for',
    whoTitle: 'This service is for you if',
    who: [
      { n: '01', text: 'You receive payments in dollars, euros, pounds or another foreign currency' },
      { n: '02', text: 'You have clients or employers in more than one country' },
      { n: '03', text: 'You are considering opening a company outside your home country' },
      { n: '04', text: 'You want to understand the tax impact of changing your tax residency' },
      { n: '05', text: 'You invest in foreign assets (stocks, ETFs, crypto, funds)' },
    ],
    ctaTitle: 'Want to map your situation with no commitment?',
    ctaBtn: 'Book a free diagnosis →',
    ctaSecondary: 'Chat on WhatsApp',
    ctaNote: 'Free consultation · 30 minutes · No commitment',
  },
  'es': {
    seoTitle: 'Planificación Financiera Internacional | Ingresos en Dólares y Euros | ConnectUP',
    seoDesc: '¿Recibes ingresos en dólares, euros o libras y no sabes cómo optimizar tu carga tributaria? Planificación financiera para profesionales con ingresos en múltiples monedas.',
    badge: 'ConnectUP',
    h1: 'Planificación Financiera',
    h1accent: 'Internacional',
    subtitle: 'Para profesionales que reciben en múltiples monedas y necesitan pagar menos impuestos — legalmente.',
    desc: 'Ganar en dólares, euros o libras es un logro. Pero sin planificación, pagas impuestos como si fueras un profesional local — perdiendo una parte significativa de lo que vino del exterior. Hay una mejor manera.',
    challengeTag: 'El problema',
    challengeTitle: 'Por qué los ingresos en múltiples monedas requieren planificación específica',
    challenges: [
      { n: '01', title: 'Cambio de divisas y tributación', desc: 'Cuando conviertes dólares a tu moneda local, no es solo un intercambio — es un evento fiscal. Dependiendo de cómo está estructurado, podrías pagar impuestos dos veces sobre el mismo monto.' },
      { n: '02', title: 'Reglas diferentes para cada fuente', desc: 'Ingresos de un cliente americano, dividendos de una empresa extranjera, salario de una firma europea — cada uno tiene tratamiento fiscal diferente.' },
      { n: '03', title: 'Estructura jurídica incorrecta', desc: 'Recibir como persona física cuando deberías recibir como empresa puede triplicar tu carga tributaria sin que lo notes.' },
      { n: '04', title: 'Fluctuación cambiaria no planificada', desc: 'El tipo de cambio sube — y con él el impuesto. Sin cobertura o estructura adecuada, pagas más impuesto justo cuando más necesitas liquidez.' },
    ],
    solutionTag: 'Lo que hacemos',
    solutionTitle: 'Cómo estructuramos tu planificación',
    solutions: [
      { icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"/>`, title: 'Diagnóstico de la situación actual', desc: 'Mapeamos todas tus fuentes de ingresos en moneda extranjera, estructuras jurídicas existentes y carga tributaria real.' },
      { icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>`, title: 'Estrategia de estructuración', desc: 'Definimos la mejor estructura para recibir — empresa paraguaya, holding internacional, cuenta no residente — según tu perfil y volumen.' },
      { icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/>`, title: 'Planificación fiscal integrada', desc: 'Integramos la planificación financiera con la fiscal — incluyendo residencia en Paraguay cuando aplica — para una visión completa y coherente.' },
    ],
    whoTag: 'Para quién',
    whoTitle: 'Este servicio es para ti si',
    who: [
      { n: '01', text: 'Recibes pagos en dólares, euros, libras u otra moneda extranjera' },
      { n: '02', text: 'Tienes clientes o empleadores en más de un país' },
      { n: '03', text: 'Estás considerando abrir una empresa fuera de tu país' },
      { n: '04', text: 'Quieres entender el impacto fiscal de cambiar tu residencia fiscal' },
      { n: '05', text: 'Inviertes en activos en el exterior (acciones, ETFs, crypto, fondos)' },
    ],
    ctaTitle: '¿Quieres mapear tu situación sin compromiso?',
    ctaBtn: 'Agendar diagnóstico gratuito →',
    ctaSecondary: 'Escribir por WhatsApp',
    ctaNote: 'Consulta gratuita · 30 minutos · Sin compromiso',
  },
  'pl': {
    seoTitle: 'Międzynarodowe Planowanie Finansowe | Dochody w Dolarach i Euro | ConnectUP',
    seoDesc: 'Otrzymujesz dochody w dolarach, euro lub funtach i nie wiesz jak zoptymalizować obciążenia podatkowe? Planowanie finansowe dla profesjonalistów z dochodami w wielu walutach.',
    badge: 'ConnectUP',
    h1: 'Planowanie Finansowe',
    h1accent: 'Międzynarodowe',
    subtitle: 'Dla profesjonalistów otrzymujących wynagrodzenie w wielu walutach, którzy chcą legalnie płacić mniej podatków.',
    desc: 'Zarabianie w dolarach, euro lub funtach to osiągnięcie. Ale bez planowania płacisz podatki jak lokalny profesjonalista — tracąc znaczną część tego, co pochodzi z zagranicy. Jest lepszy sposób.',
    challengeTag: 'Problem',
    challengeTitle: 'Dlaczego dochody w wielu walutach wymagają specjalnego planowania',
    challenges: [
      { n: '01', title: 'Przeliczanie walut i opodatkowanie', desc: 'Gdy przeliczasz dolary na złote, to nie tylko wymiana — to zdarzenie podatkowe. W zależności od struktury możesz płacić podatek dwa razy od tej samej kwoty.' },
      { n: '02', title: 'Różne zasady dla każdego źródła', desc: 'Przychód od klienta z USA, dywidenda z zagranicznej firmy, wynagrodzenie od europejskiego pracodawcy — każde ma inne traktowanie podatkowe.' },
      { n: '03', title: 'Niewłaściwa struktura prawna', desc: 'Otrzymywanie jako osoba fizyczna, gdy powinieneś otrzymywać jako firma, może potroić Twoje obciążenie podatkowe.' },
      { n: '04', title: 'Nieplanowane wahania kursów', desc: 'Kurs rośnie — i podatek też. Bez odpowiedniej struktury płacisz więcej podatku dokładnie wtedy, gdy najbardziej potrzebujesz płynności.' },
    ],
    solutionTag: 'Co robimy',
    solutionTitle: 'Jak strukturyzujemy Twoje planowanie',
    solutions: [
      { icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 19h16a2 2 0 002-2V7a2 2 0 00-2-2H4a2 2 0 00-2 2v10a2 2 0 002 2z"/>`, title: 'Diagnoza aktualnej sytuacji', desc: 'Mapujemy wszystkie Twoje źródła dochodów w walutach obcych, istniejące struktury prawne i rzeczywiste obciążenie podatkowe.' },
      { icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>`, title: 'Strategia strukturyzacji', desc: 'Definiujemy najlepszą strukturę do otrzymywania dochodów — paragwajska firma, holding międzynarodowy, konto nierezydenta — na podstawie Twojego profilu.' },
      { icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/>`, title: 'Zintegrowane planowanie podatkowe', desc: 'Integrujemy planowanie finansowe z podatkowym — w tym rezydencję w Paragwaju tam gdzie ma zastosowanie — dla pełnego obrazu.' },
    ],
    whoTag: 'Dla kogo',
    whoTitle: 'Ta usługa jest dla Ciebie jeśli',
    who: [
      { n: '01', text: 'Otrzymujesz płatności w dolarach, euro, funtach lub innej walucie obcej' },
      { n: '02', text: 'Masz klientów lub pracodawców w więcej niż jednym kraju' },
      { n: '03', text: 'Rozważasz otwarcie firmy poza swoim krajem' },
      { n: '04', text: 'Chcesz zrozumieć skutki podatkowe zmiany rezydencji podatkowej' },
      { n: '05', text: 'Inwestujesz w aktywa za granicą (akcje, ETF, krypto, fundusze)' },
    ],
    ctaTitle: 'Chcesz zmapować swoją sytuację bez zobowiązań?',
    ctaBtn: 'Umów bezpłatną diagnozę →',
    ctaSecondary: 'Napisz na WhatsApp',
    ctaNote: 'Bezpłatna konsultacja · 30 minut · Bez zobowiązań',
  },
};

const c = content[locale] ?? content['en'];
---

<BaseLayout locale={locale} title={c.seoTitle} description={c.seoDesc}>
  <div style="padding-top:80px;">

    <!-- HERO -->
    <section class="relative overflow-hidden pt-20 pb-20" style="background:linear-gradient(165deg,#1A1A1AF0 0%,#0a1e2eE8 40%,#07ffd215 100%);">
      <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] rounded-full pointer-events-none" style="background:#07ffd210;filter:blur(100px);"></div>
      <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] rounded-full pointer-events-none" style="background:#8417aa25;filter:blur(80px);"></div>
      <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image:radial-gradient(#07ffd2 1px,transparent 1px);background-size:32px 32px;"></div>

      <div class="relative max-w-[1140px] mx-auto px-6">
        <div class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-medium uppercase tracking-widest mb-8" style="background:rgba(7,255,210,0.08);border:1px solid rgba(7,255,210,0.2);color:rgba(7,255,210,0.85);font-family:'Poppins',sans-serif;">
          {c.badge}
        </div>
        <h1 style="font-family:'Poppins',sans-serif;font-size:clamp(2rem,5vw,3.2rem);font-weight:600;line-height:1.1;color:white;" class="mb-4">
          {c.h1}<br/><span style="color:#07ffd2;">{c.h1accent}</span>
        </h1>
        <p style="font-family:'Poppins',sans-serif;font-size:clamp(1rem,2vw,1.15rem);color:rgba(255,255,255,0.70);font-weight:300;max-width:640px;line-height:1.7;" class="mb-4">{c.subtitle}</p>
        <p style="font-family:'Poppins',sans-serif;font-size:0.95rem;color:rgba(255,255,255,0.60);font-weight:300;max-width:680px;line-height:1.8;">{c.desc}</p>
      </div>
    </section>

    <!-- CHALLENGES — B&W image + overlay -->
    <section class="relative py-16 px-6">
      <div class="absolute inset-0" style="background-image:url('/professional-woman.jpg');background-size:cover;background-position:center;filter:grayscale(1) brightness(0.35);"></div>
      <div class="absolute inset-0" style="background:rgba(10,30,46,0.72);"></div>
      <div class="relative max-w-[1140px] mx-auto" style="z-index:2;">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#07ffd2;">{c.challengeTag}</span>
          <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.6rem,3.5vw,2.2rem);font-weight:600;color:white;margin-top:0.5rem;">{c.challengeTitle}</h2>
        </div>
        <div class="challenge-grid">
          {c.challenges.map((item: any) => (
            <div class="glass-card">
              <div style="font-family:'Poppins',sans-serif;font-size:1.4rem;font-weight:700;color:#07ffd2;margin-bottom:0.5rem;line-height:1;">{item.n}</div>
              <h3 style="font-family:'Poppins',sans-serif;font-size:0.92rem;font-weight:600;color:white;margin-bottom:0.4rem;">{item.title}</h3>
              <p style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:300;color:rgba(255,255,255,0.75);line-height:1.6;">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SOLUTIONS — light section -->
    <section style="background:#f7f4fa;padding:4rem 1.5rem;">
      <div style="max-width:1100px;margin:0 auto;">
        <div style="text-align:center;margin-bottom:2.5rem;">
          <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#795389;margin-bottom:0.5rem;">{c.solutionTag}</span>
          <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.4rem,3vw,1.9rem);font-weight:600;color:#1a1a1a;">{c.solutionTitle}</h2>
        </div>
        <div class="solutions-grid">
          {c.solutions.map((svc: any) => (
            <div class="solution-card">
              <div style="width:48px;height:48px;border-radius:12px;background:#07ffd215;border:1px solid rgba(7,255,210,0.25);display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;flex-shrink:0;">
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#07ffd2" stroke-width="1.5" set:html={svc.icon}></svg>
              </div>
              <h3 style="font-family:'Poppins',sans-serif;font-size:1rem;font-weight:600;color:#1a1a1a;margin-bottom:0.5rem;">{svc.title}</h3>
              <p style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:300;color:#555;line-height:1.7;flex:1;">{svc.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WHO — dark + B&W -->
    <section class="relative py-16 px-6">
      <div class="absolute inset-0" style="background-image:url('/horizon-person.jpg');background-size:cover;background-position:center 30%;filter:grayscale(1) brightness(0.30);"></div>
      <div class="absolute inset-0" style="background:linear-gradient(to bottom,rgba(10,30,46,0.55),rgba(10,0,16,0.80));"></div>
      <div class="relative max-w-[900px] mx-auto" style="z-index:2;">
        <div style="text-align:center;margin-bottom:2.5rem;">
          <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#07ffd2;margin-bottom:0.75rem;">{c.whoTag}</span>
          <h2 style="font-family:'Poppins',sans-serif;font-size:clamp(1.4rem,3vw,1.9rem);font-weight:600;color:white;">{c.whoTitle}</h2>
        </div>
        <div class="who-grid">
          {c.who.map((item: any) => (
            <div style="background:rgba(255,255,255,0.07);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,0.12);border-radius:12px;padding:1.25rem 1.5rem;display:flex;align-items:flex-start;gap:0.75rem;">
              <span style="color:#07ffd2;font-weight:700;font-size:0.85rem;flex-shrink:0;font-family:'Poppins',sans-serif;">{item.n}</span>
