---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, isValidLocale, getTranslations } from '../../i18n/translations';

export function getStaticPaths() {
  return locales.map(locale => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect('/en/', 302);
const t = getTranslations(locale);
const ct = (t as any).contact ?? { thankYouTitle: 'Message sent!', thankYouText: 'We will get back to you soon.', backHome: 'Back to home' };
---

<BaseLayout locale={locale} title={ct.thankYouTitle}>
  <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#f7f4fa;padding:2rem;">
    <div style="text-align:center;max-width:480px;">
      <div style="width:72px;height:72px;border-radius:50%;background:#07ffd2;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
        <svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="#1a1a1a" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h1 style="font-family:'Poppins',sans-serif;font-size:1.75rem;font-weight:600;margin-bottom:0.75rem;">{ct.thankYouTitle}</h1>
      <p style="font-family:'Poppins',sans-serif;font-size:0.95rem;font-weight:300;color:#795389;margin-bottom:2rem;">{ct.thankYouText}</p>
      <a href={`/${locale}`} style="display:inline-flex;align-items:center;gap:8px;background:#8417aa;color:white;font-family:'Poppins',sans-serif;font-weight:500;padding:12px 24px;border-radius:8px;text-decoration:none;transition:background 0.2s;" onmouseover="this.style.background='#470050'" onmouseout="this.style.background='#8417aa'">
        {ct.backHome}
      </a>
    </div>
  </div>
</BaseLayout>
