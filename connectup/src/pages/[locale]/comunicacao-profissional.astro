    modules: [
      {
        title: 'Comunicação em reuniões internacionais',
        items: ['Abrir e conduzir reuniões', 'Participar de discussões', 'Discordar de forma profissional', 'Explicar problemas ou decisões', 'Comunicação clara em calls'],
      },
      {
        title: 'Apresentações profissionais',
        items: ['Estrutura clara de apresentação', 'Explicar projetos e resultados', 'Organizar argumentos', 'Responder perguntas com segurança'],
      },
      {
        title: 'Expressão profissional e presença',
        items: ['Clareza ao falar', 'Organização de ideias', 'Confiança ao se expressar', 'Comunicação objetiva'],
      },
      {
        title: 'Inglês corporativo aplicado',
        items: ['Vocabulário corporativo', 'Estrutura de comunicação em reuniões', 'Explicar ideias e processos', 'Conversação profissional'],
      },
    ],
    resultTag: 'Resultado esperado',
    resultTitle: 'O que você vai conquistar',
    results: [
      'Participar de reuniões internacionais com segurança e sem travar',
      'Explicar ideias e decisões com clareza em inglês — sem rodeios',
      'Apresentar projetos e resultados com estrutura e impacto',
      'Discordar, questionar e posicionar-se de forma profissional',
      'Conduzir calls sem depender de roteiros decorados',
      'Ser percebido como comunicador confiante em ambientes globais',
      'Reduzir o tempo de adaptação em equipes e clientes internacionais',
      'Transformar nervosismo em presença — dentro e fora da câmera',
    ],
    simTag: 'Prática',
    simTitle: 'Simulador de Entrevista',
    simDesc: 'Simule uma entrevista real em inglês corporativo. Receba feedback sobre estrutura, pausas e presença — antes de entrar na sala.',
    simMobileTitle: 'Disponível no computador',
    simMobileDesc: 'O simulador usa microfone e interações avançadas. Acesse pelo computador para a experiência completa.',
    simMobileBtn: 'Abrir em tela cheia →',
    ctaTitle: 'Pronto para se comunicar com confiança no mundo?',
    ctaBtn: 'Agendar agora →',
    ctaSecondary: 'Fale com a gente',
    ctaNote: 'Consulta gratuita · Sem compromisso',
  },
  'en': {
    seoTitle: 'International Professional Communication | ConnectUP',
    seoDesc: 'Develop your English communication skills for global corporate environments. Meetings, presentations and professional presence with clarity and confidence.',
    badge: 'ConnectUP Program',
    h1: 'International Professional',
    h1accent: 'Communication',
    subtitle: 'Communication development for global corporate environments.',
    desc: 'This program combines corporate English, professional speaking and communication in international meetings. The goal is to improve clarity, confidence and structure when communicating with foreign teams and clients.',
    forWhoTag: 'Who it is for',
    forWhoTitle: 'Built for global professionals',
    audience: [
      { n: '01', text: 'Work with foreign companies' },
