---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import { locales, isValidLocale } from '../../i18n/translations';

export function getStaticPaths() {
  return locales.map(locale => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect('/en/', 302);

const simUrl = locale === 'pt-br' ? '/simulador-entrevista.html' : '/interview-simulator.html';

const content: Record<string, any> = {
  'pt-br': {
    seoTitle: 'Comunicação Profissional Internacional | ConnectUP',
    seoDesc: 'Desenvolva sua comunicação em inglês para ambientes corporativos globais. Reuniões, apresentações e presença profissional com clareza e confiança.',
    badge: 'Programa ConnectUP',
    h1: 'Comunicação Profissional',
    h1accent: 'Internacional',
    subtitle: 'Desenvolvimento de comunicação para ambientes corporativos globais.',
    desc: 'Este programa combina inglês corporativo, oratória profissional e comunicação em reuniões internacionais. O objetivo é melhorar clareza, segurança e estrutura ao se comunicar com equipes e clientes estrangeiros.',
    forWhoTag: 'Para quem é indicado',
    forWhoTitle: 'Feito para profissionais globais',
    audience: [
      { n: '01', text: 'Trabalham com empresas estrangeiras' },
      { n: '02', text: 'Participam de reuniões em inglês' },
      { n: '03', text: 'Precisam apresentar ideias com clareza' },
      { n: '04', text: 'Querem melhorar presença e comunicação profissional' },
