---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales, isValidLocale } from '../../i18n/translations';

export function getStaticPaths() {
  return locales.map(locale => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isValidLocale(locale)) return Astro.redirect('/en/', 302);

const content: Record<string, any> = {
  'pt-br': {
    seoTitle: 'Sobre a ConnectUP — Especialistas em Residência Fiscal no Paraguai',
    seoDesc: 'Conheça a ConnectUP, consultoria especializada em residência fiscal no Paraguai para brasileiros. Processo legal, seguro e com suporte jurídico completo.',
    label: 'Fundadora & Consultora Internacional',
    h1: 'A ponte entre você e o sistema que vai te libertar.',
    bio: 'Vim até o Paraguai para entender o sistema por dentro. Construí relacionamentos com advogados, contadores e especialistas locais; mapeei cada etapa do processo; e me tornei o elo que faltava para empreendedores e empresários que querem fazer isso com segurança. Hoje a ConnectUp atende pessoas do Brasil, Polônia, Espanha e de todo o mundo, com clareza, método e profissionais de confiança do início ao fim.',
    quote: 'Minha missão é simples: ajudar você a guardar mais do que ganha, de onde quer que você esteja.',
    bridgeCaption: 'Estratégia e acompanhamento',
    stats: [{ n:'3+', l:'Continentes atendidos' }, { n:'100%', l:'Legal e seguro' }, { n:'1', l:'Ponto de contato para tudo' }],
    servicesTitle: 'O que fazemos',
    services: ['Residência fiscal no Paraguai', 'Abertura de empresa e Maquila', 'Planejamento tributário internacional', 'Consultoria estratégica personalizada'],
    valuesTitle: 'Nossos valores',
    values: ['Clareza antes de tudo', 'Só o que é legal', 'Estrutura própria, não improviso'],
    ctaTitle: 'Pronto para guardar mais do que ganha?',
    ctaBtn: 'Fale com a gente →',
  },
  'en': {
    seoTitle: 'About ConnectUP — Paraguay Tax Residency Specialists',
    seoDesc: 'Meet ConnectUP, specialists in Paraguay tax residency. Legal, safe process with full legal support from start to finish.',
    label: 'Founder & International Consultant',
    h1: 'The bridge between you and the system that will set you free.',
    bio: 'I came to Paraguay to understand the system from the inside. I built relationships with local lawyers, accountants and specialists; mapped every step of the process; and became the missing link for entrepreneurs and business owners who want to do this safely. Today ConnectUp serves people from Brazil, Poland, Spain and around the world, with clarity, method and trusted professionals from start to finish.',
    quote: 'My mission is simple: help you keep more of what you earn, wherever you are.',
    bridgeCaption: 'Strategy and guidance',
    stats: [{ n:'3+', l:'Continents served' }, { n:'100%', l:'Legal and safe' }, { n:'1', l:'Single point of contact' }],
    servicesTitle: 'What we do',
    services: ['Tax residency in Paraguay', 'Company setup and Maquila', 'International tax planning', 'Personalized strategic consulting'],
    valuesTitle: 'Our values',
    values: ['Clarity first', 'Only what is legal', 'Proper structure, not improvisation'],
    ctaTitle: 'Ready to keep more of what you earn?',
    ctaBtn: 'Get in Touch →',
  },
  'es': {
    seoTitle: 'Sobre ConnectUP — Especialistas en Residencia Fiscal en Paraguay',
    seoDesc: 'Conoce ConnectUP, consultoría especializada en residencia fiscal en Paraguay. Proceso legal, seguro y con soporte jurídico completo.',
    label: 'Fundadora & Consultora Internacional',
    h1: 'El puente entre tú y el sistema que te va a liberar.',
    bio: 'Vine a Paraguay para entender el sistema desde adentro. Construí relaciones con abogados, contadores y especialistas locales; mapeé cada etapa del proceso; y me convertí en el eslabón que faltaba para emprendedores y empresarios que quieren hacer esto con seguridad. Hoy ConnectUp atiende personas de Brasil, Polonia, España y de todo el mundo, con claridad, método y profesionales de confianza de principio a fin.',
    quote: 'Mi misión es simple: ayudarte a conservar más de lo que ganas, desde donde estés.',
    bridgeCaption: 'Estrategia y acompañamiento',
    stats: [{ n:'3+', l:'Continentes atendidos' }, { n:'100%', l:'Legal y seguro' }, { n:'1', l:'Un solo punto de contacto' }],
    servicesTitle: 'Qué hacemos',
    services: ['Residencia fiscal en Paraguay', 'Apertura de empresa y Maquila', 'Planificación tributaria internacional', 'Consultoría estratégica personalizada'],
    valuesTitle: 'Nuestros valores',
    values: ['Claridad ante todo', 'Solo lo que es legal', 'Estructura propia, no improvisación'],
    ctaTitle: '¿Listo para guardar más de lo que ganas?',
    ctaBtn: 'Contáctanos →',
  },
  'pl': {
    seoTitle: 'O ConnectUP — Specjaliści ds. Rezydencji Podatkowej w Paragwaju',
    seoDesc: 'Poznaj ConnectUP, specjalistów od rezydencji podatkowej w Paragwaju. Legalny, bezpieczny proces z pełnym wsparciem prawnym.',
    label: 'Założycielka & Konsultantka Międzynarodowa',
    h1: 'Most między Tobą a systemem, który Cię wyzwoli.',
    bio: 'Przyjechałam do Paragwaju, aby zrozumieć system od środka. Zbudowałam relacje z lokalnymi prawnikami, księgowymi i specjalistami; zmapowałam każdy etap procesu; i stałam się brakującym ogniwem dla przedsiębiorców, którzy chcą to zrobić bezpiecznie. Dziś ConnectUp obsługuje osoby z Brazylii, Polski, Hiszpanii i całego świata, z jasnością, metodą i zaufanymi profesjonalistami od początku do końca.',
    quote: 'Moja misja jest prosta: pomóc Ci zachować więcej z tego, co zarabiasz, gdziekolwiek jesteś.',
    bridgeCaption: 'Strategia i wsparcie',
    stats: [{ n:'3+', l:'Obsługiwane kontynenty' }, { n:'100%', l:'Legalnie i bezpiecznie' }, { n:'1', l:'Jeden punkt kontaktu' }],
    servicesTitle: 'Co robimy',
    services: ['Rezydencja podatkowa w Paragwaju', 'Zakładanie firm i Maquila', 'Międzynarodowe planowanie podatkowe', 'Spersonalizowane doradztwo strategiczne'],
    valuesTitle: 'Nasze wartości',
    values: ['Przejrzystość przede wszystkim', 'Tylko to, co jest legalne', 'Własna struktura, nie improwizacja'],
    ctaTitle: 'Gotowy, by zachować więcej z tego, co zarabiasz?',
    ctaBtn: 'Skontaktuj się →',
  },
};

const c = content[locale] ?? content['en'];
---

<BaseLayout locale={locale} title={c.seoTitle} description={c.seoDesc}>
  <div style="padding-top:80px;">

    <!-- Hero: photo + text -->
    <section style="background:#f7f4fa;padding:4rem 1.5rem;">
      <div style="max-width:1140px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;" class="about-grid">
        <div>
          <span style="display:block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#795389;margin-bottom:0.75rem;">{c.label}</span>
          <h1 style="font-family:'Poppins',sans-serif;font-size:clamp(1.4rem,3vw,1.75rem);font-weight:600;line-height:1.3;margin-bottom:1.25rem;">{c.h1}</h1>
          <p style="font-family:'Poppins',sans-serif;font-size:0.95rem;font-weight:300;line-height:1.8;color:#444;margin-bottom:1.5rem;">{c.bio}</p>
          <blockquote style="border-left:3px solid #8417aa;background:#fff;padding:1rem 1.25rem;border-radius:0 8px 8px 0;font-family:'Poppins',sans-serif;font-size:0.9rem;font-weight:400;font-style:italic;color:#333;">
            {c.quote}
          </blockquote>
        </div>
        <div>
          <img src="/lana-profissa.jpg" alt="Lana — ConnectUp" style="width:100%;border-radius:14px;object-fit:cover;max-height:480px;" />
        </div>
      </div>
    </section>

    <!-- Bridge pill -->
    <section style="padding:2.5rem 1.5rem;text-align:center;background:white;">
      <span style="display:inline-block;font-family:'Poppins',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#795389;background:#f7f4fa;border:1px solid #dfdede;padding:6px 16px;border-radius:99px;">ConnectUp</span>
      <p style="font-family:'Poppins',sans-serif;font-size:0.85rem;font-weight:300;color:#795389;margin-top:0.5rem;">{c.bridgeCaption}</p>
    </section>

    <!-- Stats -->
    <section style="background:#f7f4fa;padding:3rem 1.5rem;">
      <div style="max-width:700px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;text-align:center;" class="stats-grid">
        {c.stats.map((s: any) => (
          <div>
            <div style="font-family:'Poppins',sans-serif;font-size:2.2rem;font-weight:600;color:#8417aa;">{s.n}</div>
            <div style="font-family:'Poppins',sans-serif;font-size:0.82rem;font-weight:400;color:#795389;margin-top:4px;">{s.l}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Services grid 2x2 -->
    <section style="padding:4rem 1.5rem;background:white;">
      <div style="max-width:800px;margin:0 auto;">
        <h2 style="font-family:'Poppins',sans-serif;font-size:1.3rem;font-weight:600;text-align:center;margin-bottom:2rem;">{c.servicesTitle}</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;" class="services2x2">
          {c.services.map((s: string, i: number) => (
            <div style={`border:1px solid #dfdede;border-radius:10px;padding:1.25rem 1.5rem;border-left:4px solid ${i % 2 === 0 ? '#8417aa' : '#07ffd2'};`}>
              <p style="font-family:'Poppins',sans-serif;font-size:0.9rem;font-weight:500;color:#1a1a1a;">{s}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Values grid 3 -->
    <section style="background:#f7f4fa;padding:4rem 1.5rem;">
      <div style="max-width:900px;margin:0 auto;">
        <h2 style="font-family:'Poppins',sans-serif;font-size:1.3rem;font-weight:600;text-align:center;margin-bottom:2rem;">{c.valuesTitle}</h2>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;" class="values-grid">
          {c.values.map((v: string) => (
            <div style="background:white;border:1px solid #dfdede;border-radius:10px;padding:1.25rem 1.5rem;text-align:center;">
              <p style="font-family:'Poppins',sans-serif;font-size:0.9rem;font-weight:500;color:#1a1a1a;">{v}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA block -->
    <section style="background:#8417aa;padding:4rem 1.5rem;text-align:center;">
      <h3 style="font-family:'Poppins',sans-serif;font-size:1.5rem;font-weight:600;color:white;margin-bottom:1.5rem;">{c.ctaTitle}</h3>
      <a href="https://wa.me/5511913062315" target="_blank" rel="noopener noreferrer" style="display:inline-flex;align-items:center;gap:8px;background:white;color:#8417aa;font-family:'Poppins',sans-serif;font-weight:500;padding:14px 28px;border-radius:8px;transition:all 0.2s;" onmouseover="this.style.background='#e1a7f1'" onmouseout="this.style.background='white'">
        {c.ctaBtn}
      </a>
    </section>
  </div>
</BaseLayout>

<style>
@media (max-width: 768px) {
  .about-grid { grid-template-columns: 1fr !important; }
  .stats-grid { grid-template-columns: repeat(2, 1fr) !important; }
  .services2x2 { grid-template-columns: 1fr !important; }
  .values-grid { grid-template-columns: 1fr !important; }
}
</style>
