---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout locale="pt-br" title="Mensagem enviada">
  <section class="pt-[120px] pb-20 min-h-screen flex items-center justify-center" style="background:#f7f4fa;">
    <div class="max-w-[480px] mx-auto px-6 text-center">
      <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6" style="background:#07ffd2;">
        <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#000" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h1 style="font-family:'Poppins',sans-serif;font-size:2rem;font-weight:600;margin-bottom:1rem;">Mensagem enviada!</h1>
      <p style="font-family:'Poppins',sans-serif;font-weight:300;color:#555;margin-bottom:2rem;">Recebemos sua mensagem e responderemos em até 24 horas.</p>
      <a href="/pt-br" class="btn-primary">Voltar ao início</a>
    </div>
  </section>
</BaseLayout>
