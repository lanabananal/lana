---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const t = getTranslations(locale);

const siteUrl = 'https://www.theconnectup.com';
const pageTitle = title ? `${title} — ConnectUP` : 'ConnectUP — Paraguay Tax Residency | Legal & Fast';
const pageDesc = description ?? t.hero.subheadline;
const canonicalPath = Astro.url.pathname;
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImage = `${siteUrl}/og-image.png`;

const localePath = canonicalPath.replace(/^\/(en|pt-br|pl|es)/, '');

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: 'ConnectUP',
      url: siteUrl,
      logo: {
        '@type': 'ImageObject',
        url: `${siteUrl}/C_COLORIDO.png`,
      },
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: '+55-11-91306-2315',
        contactType: 'customer service',
        availableLanguage: ['Portuguese', 'English', 'Spanish', 'Polish'],
      },
      sameAs: [
        'https://www.linkedin.com/company/theconnectup/',
        'https://www.youtube.com/@Connectupbr',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'ConnectUP',
      publisher: { '@id': `${siteUrl}/#organization` },
    },
    {
      '@type': 'Service',
      '@id': `${siteUrl}/#service`,
      name: 'Paraguay Tax Residency Consulting',
      provider: { '@id': `${siteUrl}/#organization` },
      description: 'Legal Paraguay tax residency process for individuals and companies. Foreign income 0% taxed. Two trips to Asunción.',
      areaServed: { '@type': 'Country', name: 'Paraguay' },
      serviceType: 'Tax Residency Consulting',
    },
  ],
};
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="robots" content="index, follow" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="ConnectUP" />
    <meta property="og:locale" content={locale === 'pt-br' ? 'pt_BR' : locale === 'pl' ? 'pl_PL' : locale === 'es' ? 'es_ES' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Alternate language links -->
    <link rel="alternate" hreflang="en"    href={`${siteUrl}/en${localePath}`} />
    <link rel="alternate" hreflang="pt-BR" href={`${siteUrl}/pt-br${localePath}`} />
    <link rel="alternate" hreflang="pl"    href={`${siteUrl}/pl${localePath}`} />
    <link rel="alternate" hreflang="es"    href={`${siteUrl}/es${localePath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en${localePath}`} />

    <link rel="icon" type="image/png" href="/C_COLORIDO.png" />
    <title>{pageTitle}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar locale={locale} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
