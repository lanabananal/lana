---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  pubDate?: Date;
  postAuthor?: string;
  hreflangUrls?: Record<string, string>;
}

const { locale, title, description, ogType = 'website', pubDate, postAuthor, hreflangUrls } = Astro.props;
const t = getTranslations(locale);
const siteUrl = 'https://theconnectup.com';

const defaultTitles: Record<string, string> = {
  'pt-br': 'ConnectUP — Mobilidade Profissional Global 360°',
  'en':    'ConnectUP — 360° Global Professional Mobility',
  'es':    'ConnectUP — Movilidad Profesional Global 360°',
  'pl':    'ConnectUP — Globalna Mobilność Zawodowa 360°',
};

const defaultDescs: Record<string, string> = {
  'pt-br': 'Comunicação profissional em inglês, adequação de CV & LinkedIn e planejamento fiscal no Paraguai. Tudo que você precisa para atuar com liberdade no mercado global.',
  'en':    'Professional communication in English, CV & LinkedIn optimization, and Paraguay tax planning. Everything you need to work freely in the global market. ConnectUP.',
  'es':    'Comunicación profesional en inglés, adecuación de CV y LinkedIn y planificación fiscal en Paraguay. ConnectUP — tu solución 360° para la movilidad global.',
  'pl':    'Profesjonalna komunikacja po angielsku, optymalizacja CV i LinkedIn oraz planowanie podatkowe w Paragwaju. ConnectUP — Twoje rozwiązanie 360° dla globalnej mobilności.',
};

const pageTitle = title
  ? `${title} | ConnectUP`
  : (defaultTitles[locale] ?? 'ConnectUP — 360° Global Professional Mobility');

const pageDesc = description
  ?? defaultDescs[locale]
  ?? t.hero.subheadline;

const pageKeywords: Record<string, string> = {
  'en':    'Paraguay tax residency, Paraguay cedula, territorial tax system, 0% foreign income tax, professional mobility, CV LinkedIn international, company formation Paraguay',
  'pt-br': 'residência fiscal Paraguai, cédula paraguaia, planejamento fiscal, imposto renda exterior, mobilidade profissional, CV LinkedIn internacional, abertura empresa Paraguai',
  'es':    'residencia fiscal Paraguay, cédula paraguaya, planificación fiscal, impuesto renta extranjera, movilidad profesional, CV LinkedIn internacional, empresa Paraguay',
  'pl':    'rezydencja podatkowa Paragwaj, cédula paragwajska, planowanie podatkowe, podatek dochód zagraniczny, mobilność zawodowa, CV LinkedIn internationale',
};

const canonicalPath = Astro.url.pathname;
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImage = `${siteUrl}/C_COLORIDO.png`;
const localePath = canonicalPath.replace(/^\/(en|pt-br|pl|es)/, '');

const defaultHreflangUrls: Record<string, string> = {
  'en':       `${siteUrl}/en${localePath}`,
  'pt-BR':    `${siteUrl}/pt-br${localePath}`,
  'pl':       `${siteUrl}/pl${localePath}`,
  'es':       `${siteUrl}/es${localePath}`,
  'x-default': `${siteUrl}/en${localePath}`,
};

const resolvedHreflangUrls = hreflangUrls ?? defaultHreflangUrls;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      '@id': `${siteUrl}/#organization`,
      name: 'ConnectUP',
      url: siteUrl,
      logo: {
        '@type': 'ImageObject',
        url: `${siteUrl}/C_COLORIDO.png`,
      },
      image: `${siteUrl}/C_COLORIDO.png`,
      description: 'Paraguay tax residency and international professional mobility services. Full legal support for cedula, RUC, company formation, CV & LinkedIn optimization and professional communication.',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Edificio Atrium',
        addressLocality: 'Asunción',
        addressRegion: 'Asunción',
        addressCountry: 'PY',
      },
      telephone: '+595991507955',
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: '+595991507955',
        contactType: 'customer service',
        availableLanguage: ['Portuguese', 'English', 'Spanish', 'Polish'],
      },
      sameAs: [
        'https://www.linkedin.com/company/theconnectup/',
        'https://www.youtube.com/@Connectupbr',
        'https://www.instagram.com/theconnectup/',
      ],
      areaServed: [
        { '@type': 'Country', name: 'Paraguay' },
        { '@type': 'Country', name: 'Brazil' },
        { '@type': 'Country', name: 'United States' },
        { '@type': 'Country', name: 'Poland' },
        { '@type': 'Country', name: 'Argentina' },
        { '@type': 'Country', name: 'Spain' },
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'ConnectUP Services',
        itemListElement: [
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Paraguay Tax Residency', description: 'Complete legal Paraguay tax residency including cedula, RUC and SET certificate. 0% tax on foreign income.' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Paraguay Company Formation', description: 'Full company registration in Paraguay — SAE, SRL or SA — with legal support.' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'CV & LinkedIn Optimization', description: 'Resume and LinkedIn profile restructured for international ATS standards.' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Professional Communication', description: 'Corporate English, STAR method coaching and international presentation training.' } },
        ],
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: 'ConnectUP',
      publisher: { '@id': `${siteUrl}/#organization` },
    },
    {
      '@type': 'Service',
      '@id': `${siteUrl}/#service-tax`,
      name: 'Paraguay Tax Residency Consulting',
      provider: { '@id': `${siteUrl}/#organization` },
      description: 'Legal Paraguay tax residency process for individuals and companies. 0% tax on foreign income. Full legal support. Two trips to Asunción.',
      areaServed: { '@type': 'Country', name: 'Paraguay' },
      serviceType: 'Tax Planning & Residency Consulting',
    },
    {
      '@type': 'Service',
      '@id': `${siteUrl}/#service-communication`,
      name: 'International Professional Communication',
      provider: { '@id': `${siteUrl}/#organization` },
      description: 'Corporate English, international meetings, professional presentations and STAR method coaching for global professionals.',
      serviceType: 'Professional Communication Training',
    },
    {
      '@type': 'Service',
      '@id': `${siteUrl}/#service-cv`,
      name: 'CV & LinkedIn Optimization for International Market',
      provider: { '@id': `${siteUrl}/#organization` },
      description: 'Resume restructuring and LinkedIn profile optimization aligned with international standards and ATS systems.',
      serviceType: 'Career Positioning & Resume Consulting',
    },
  ],
};
---
<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta name="keywords" content={pageKeywords[locale] ?? pageKeywords['en']} />
    <meta name="robots" content="index, follow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="ConnectUP" />
    <meta property="og:locale" content={locale === 'pt-br' ? 'pt_BR' : locale === 'pl' ? 'pl_PL' : locale === 'es' ? 'es_ES' : 'en_US'} />
    {ogType === 'article' && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {ogType === 'article' && postAuthor && (
      <meta property="article:author" content={postAuthor} />
    )}
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Alternate language links -->
    {Object.entries(resolvedHreflangUrls).map(([lang, url]) => (
      <link rel="alternate" hreflang={lang} href={url} />
    ))}
    <link rel="icon" type="image/png" href="/C_COLORIDO.png" />
    <title>{pageTitle}</title>
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar locale={locale} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
