---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getTranslations } from '../i18n/translations';

interface Props {
  locale: string;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const t = getTranslations(locale);

const pageTitle = title ? `${title} — ConnectUp` : 'ConnectUp — Paraguay Tax Residency';
const pageDesc = description ?? t.hero.subheadline;
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>

    <!-- Alternate language links -->
    <link rel="alternate" hreflang="en"    href={`/en${Astro.url.pathname.replace(/^\/(en|pt-br|pl|es)/, '')}`} />
    <link rel="alternate" hreflang="pt-br" href={`/pt-br${Astro.url.pathname.replace(/^\/(en|pt-br|pl|es)/, '')}`} />
    <link rel="alternate" hreflang="pl"    href={`/pl${Astro.url.pathname.replace(/^\/(en|pt-br|pl|es)/, '')}`} />
    <link rel="alternate" hreflang="es"    href={`/es${Astro.url.pathname.replace(/^\/(en|pt-br|pl|es)/, '')}`} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar locale={locale} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
